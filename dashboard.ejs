<%
  // The same instruments as the business portal, asking an individual's questions.
  const openC   = cases.filter(c => !['settled','declined','closed'].includes(c.status));
  const mineC   = cases.filter(c => c.claimant_id === me.id);         // ones I raised
  const owedC   = openC.filter(c => c.claimant_id === me.id);
  const settled = cases.filter(c => c.status === 'settled');
  const sum = (arr, k) => arr.reduce((a, c) => a + (c[k] || 0), 0);

  const owed = sum(owedC, 'amount');
  const needs = cases.filter(c => c.stalled).length;
  const recovered = sum(settled.filter(c => c.claimant_id === me.id), 'settled_value');

  const spans = settled
    .filter(c => c.settled_at && c.created_at)
    .map(c => Math.max(0, Math.round((new Date(c.settled_at) - new Date(c.created_at)) / 86400000)));
  const typical = spans.length ? Math.round(spans.reduce((a, b) => a + b, 0) / spans.length) : null;

  const cur = cases[0] ? cases[0].currency : 'GBP';
  const STAGE_META = {
    draft:      { label: 'Draft',       color: '#B4B2A9' },
    awaiting:   { label: 'Awaiting',    color: '#F5B312' },
    progress:   { label: 'In progress', color: '#2F6BFF' },
    bidding:    { label: 'Bidding — rounds in play',  color: '#2F6BFF' },
    settled:    { label: 'Settled',     color: '#15B877' }
  };
  const STAGES = ['draft','awaiting','bidding','settled'];
  const countAt = (s) => cases.filter(c => c.stage === s).length;

  // Eight-week trends from the timestamps already on each case — real, not mocked.
  const WEEKS = 8, WEEK = 7 * 86400000, now = Date.now();
  const edges = [];
  for (let k = WEEKS - 1; k >= 0; k--) edges.push(now - k * WEEK);
  const madeBy = (c, t) => new Date(c.created_at).getTime() <= t;
  const doneBy = (c, t) => c.settled_at && new Date(c.settled_at).getTime() <= t;
  const sOwed = edges.map(t => cases.filter(c => c.claimant_id === me.id && madeBy(c, t) && !doneBy(c, t) && !['closed','declined'].includes(c.status)).reduce((a, c) => a + c.amount, 0));
  const sRec  = edges.map(t => cases.filter(c => c.claimant_id === me.id && doneBy(c, t)).reduce((a, c) => a + (c.settled_value || 0), 0));
  const sNeed = edges.map(t => cases.filter(c => madeBy(c, t) && c.stalled).length);
  const delta = (arr) => arr[arr.length - 1] - arr[Math.max(0, arr.length - 5)];

  function sparkPts(points) {
    const w = 100, h = 26;
    const max = Math.max.apply(null, points), min = Math.min.apply(null, points);
    const range = (max - min) || 1;
    return points.map((p, i) => ((i / (points.length - 1)) * w).toFixed(1) + ',' + (h - 2 - ((p - min) / range) * (h - 4)).toFixed(1)).join(' ');
  }
  const filter = typeof f === 'undefined' ? (locals.filter || 'all') : f;
%>
<%- include('partials/head', { pageHead: {
  eyebrow: 'Your cases',
  title: cases.length ? (openC.length + ' open, ' + settled.length + ' settled') : 'No cases yet',
  sub: "Open a new dispute, or continue one you're already part of."
} }) %>

<style>
/* Scoped to the individual dashboard so styles.css needs no changes. */

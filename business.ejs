<%
  // ---- Trends -----------------------------------------------------------------
  // Computed from the timestamps already on each case, so the sparklines are
  // honest rather than decorative.
  const WEEKS = 8, WEEK = 7 * 86400000, now = Date.now();
  const edges = [];
  for (let k = WEEKS - 1; k >= 0; k--) edges.push(now - k * WEEK);
  const createdBy = (c, t) => new Date(c.created_at).getTime() <= t;
  const settledBy = (c, t) => c.settled_at && new Date(c.settled_at).getTime() <= t;

  const sInDispute = edges.map(t => cases.filter(c => createdBy(c, t) && !settledBy(c, t) && !['closed','declined'].includes(c.status)).reduce((a, c) => a + c.amount, 0));
  const sSettled  = edges.map(t => cases.filter(c => settledBy(c, t)).reduce((a, c) => a + (c.settled_value || 0), 0));
  const sJoin = edges.map(t => {
    const inv = cases.filter(c => createdBy(c, t) && c.stage !== 'draft');
    const jn = inv.filter(c => ['progress','converging','settled'].includes(c.stage) || c.status === 'declined');
    return inv.length ? Math.round(jn.length / inv.length * 100) : 0;
  });
  const sBand = edges.map(t => cases.filter(c => createdBy(c, t) && c.stage === 'converging').length);
  const delta = (arr) => arr[arr.length - 1] - arr[Math.max(0, arr.length - 5)];
  const cur = kpis.currency;

  const STAGE_META = {
    draft:      { label: 'Draft',       color: '#B4B2A9' },
    awaiting:   { label: 'Awaiting',    color: '#F5B312' },
    progress:   { label: 'In progress', color: '#2F6BFF' },
    converging: { label: 'Converging',  color: '#16306B' },
    settled:    { label: 'Settled',     color: '#15B877' }
  };
  function sparkPts(points) {
    const w = 100, h = 28;
    const max = Math.max.apply(null, points), min = Math.min.apply(null, points);
    const range = (max - min) || 1;
    return points.map((p, i) => ((i / (points.length - 1)) * w).toFixed(1) + ',' + (h - 2 - ((p - min) / range) * (h - 4)).toFixed(1)).join(' ');
  }
%>

/* =============================================================================
   COLOUR — one theme, same tokens as the homepage, but every number earns an
   identity so the page reads at a glance instead of label by label.

   The bright brand colours are FILLS and BORDERS only. As text on white they
   fail outright: gold #F5B312 is 1.85:1, green #15B877 is 2.58:1. The numbers
   therefore use the deep variants, which pass comfortably:
     royal  #2F6BFF   4.50:1   (numbers are 29px = large text, needs 3:1)
     gold   #B5790F   3.68:1   large
     navy   #16306B  12.58:1
     green  #1c5e3f   7.71:1
   ========================================================================== */
.kpis .kpi{border-left:5px solid var(--line)}
.kpis .kpi:nth-child(1){border-left-color:#2F6BFF;background:linear-gradient(180deg,rgba(47,107,255,.08),#fff 62%)}
.kpis .kpi:nth-child(1) .kpi-num{color:#2F6BFF}
.kpis .kpi:nth-child(2){border-left-color:#F5B312;background:linear-gradient(180deg,rgba(245,179,18,.13),#fff 62%)}
.kpis .kpi:nth-child(2) .kpi-num{color:#B5790F}
.kpis .kpi:nth-child(3){border-left-color:#16306B;background:linear-gradient(180deg,rgba(22,48,107,.08),#fff 62%)}
.kpis .kpi:nth-child(3) .kpi-num{color:#16306B}
.kpis .kpi:nth-child(4){border-left-color:#15B877;background:linear-gradient(180deg,rgba(21,184,119,.10),#fff 62%)}
.kpis .kpi:nth-child(4) .kpi-num{color:#1c5e3f}

/* Pipeline: each stage tinted with its own colour, so the shape of your ledger
   is visible before you read a word. Active stage fills solid — with ink chosen
   per stage, because white on gold or on grey would be unreadable. */
.pathstep{--st:#B4B2A9;--sto:#1E2A45;background:color-mix(in srgb,var(--st) 14%,#F3F6FB)}
.pathstep:nth-child(2){--st:#F5B312;--sto:#2E2000}
.pathstep:nth-child(3){--st:#2A61EE;--sto:#FFFFFF}
.pathstep:nth-child(4){--st:#16306B;--sto:#FFFFFF}
.pathstep:nth-child(5){--st:#15B877;--sto:#062A1B}
.pathstep:hover{background:color-mix(in srgb,var(--st) 26%,#F3F6FB)}
.pathstep.on{background:var(--st);color:var(--sto)}
.pathstep.on:hover{background:var(--st)}
.pathstep.on .ps-count{color:var(--sto)}
.pathstep .ps-count{color:#16306B}
</style>

<% if (flash) { %><div class="flash"><%= flash %></div><% } %>

<!-- ============ KPI TILES ============ -->
<div class="kpis">
  <div class="kpi">
    <div class="kpi-label">Total in dispute</div>
    <div class="kpi-num"><%= money(kpis.totalInDispute, cur) %></div>
    <% const dD = delta(sInDispute); %>
    <div class="kpi-delta <%= dD > 0 ? 'up' : (dD < 0 ? 'down' : 'flat') %>"><%= dD === 0 ? '—' : (dD > 0 ? '▲ ' : '▼ ') + money(Math.abs(dD), cur) %> <span class="sub">vs 4 weeks ago</span></div>
    <svg class="kpi-spark" viewBox="0 0 100 28" preserveAspectRatio="none"><polyline points="<%= sparkPts(sInDispute) %>" fill="none" stroke="#2F6BFF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
  <div class="kpi">
    <div class="kpi-label">Respondent join rate</div>
    <div class="kpi-num"><%= kpis.joinRate %>%</div>
    <% const dJ = delta(sJoin); %>
    <div class="kpi-delta <%= dJ > 0 ? 'up' : (dJ < 0 ? 'down' : 'flat') %>"><%= dJ === 0 ? '—' : (dJ > 0 ? '▲ ' : '▼ ') + Math.abs(dJ) + ' pts' %> <span class="sub">vs 4 weeks ago</span></div>
    <svg class="kpi-spark" viewBox="0 0 100 28" preserveAspectRatio="none"><polyline points="<%= sparkPts(sJoin) %>" fill="none" stroke="#2F6BFF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
  <a class="kpi <%= filter === 'converging' ? 'on' : '' %>" href="/business?filter=<%= filter === 'converging' ? 'all' : 'converging' %>">
    <div class="kpi-label">In settlement band</div>
    <div class="kpi-num"><%= kpis.inBand %></div>
    <div class="kpi-delta flat">Ready to approve <span class="sub">glance &amp; sign</span></div>
    <svg class="kpi-spark" viewBox="0 0 100 28" preserveAspectRatio="none"><polyline points="<%= sparkPts(sBand) %>" fill="none" stroke="#16306B" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
  <div class="kpi">
    <div class="kpi-label">Settled value</div>
    <div class="kpi-num"><%= money(kpis.settledValue, cur) %></div>
    <% const dS = delta(sSettled); %>
    <div class="kpi-delta <%= dS > 0 ? 'up' : 'flat' %>"><%= dS === 0 ? '—' : '▲ ' + money(dS, cur) %> <span class="sub">last 4 weeks</span></div>
    <svg class="kpi-spark" viewBox="0 0 100 28" preserveAspectRatio="none"><polyline points="<%= sparkPts(sSettled) %>" fill="none" stroke="#15B877" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</div>

<!-- ============ PIPELINE ============ -->
<div class="bcard">
  <div class="ov-head"><div><div class="ov-title">Pipeline</div><div class="b-muted">Click a stage to filter the list below.</div></div></div>
  <div class="path">
    <% stages.forEach(function (s) { const m = STAGE_META[s]; %>
      <a class="pathstep <%= filter === s ? 'on' : '' %>" href="/business?filter=<%= filter === s ? 'all' : s %>">
        <div class="ps-name"><span class="ps-dot" style="background:<%= m.color %>"></span><%= m.label %></div>
        <div class="ps-count"><%= counts[s] %></div>
      </a>
    <% }); %>
  </div>
  <% if (counts.declined) { %>
    <div class="path-extra">
      <a class="declined-chip <%= filter === 'declined' ? 'on' : '' %>" href="/business?filter=<%= filter === 'declined' ? 'all' : 'declined' %>">Declined · <%= counts.declined %></a>
      <span class="b-muted">off-pipeline — needs a fresh invite or closing</span>
    </div>
  <% } %>
</div>

<% if (counts.noemail) { %>
  <div class="alert warn">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01M10.3 3.9L1.8 18a2 2 0 001.7 3h17a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/></svg>
    <div><b><%= counts.noemail %> dispute<%= counts.noemail === 1 ? ' has' : 's have' %> no email address yet.</b> MidBid invites the other side by email — these can't be sent until one is added. Click the email cell in the list to type it in. <a href="/business?filter=noemail" style="color:#8a3d1a;font-weight:700">Show them</a></div>
  </div>
<% } %>

<!-- ============ BID BAR ============ -->
<div class="bcard">
  <div class="bidbar-head">
    <div class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 20V10M12 20V4M20 20v-7"/></svg></div>
    <div><div class="ov-title">Your bid bar</div><div class="b-muted">Three figures, set once as a share of each dispute's value — saved as presets, applied across cases.</div></div>
  </div>
  <form method="POST" action="/business/bidbar" id="barForm">
    <div class="preset-row">
      <label for="presetSel">Preset</label>
      <select id="presetSel" onchange="loadPreset()">
        <option value="-1">Custom…</option>
        <% presets.forEach(function (p) { %><option value="<%= p.ideal_pct %>|<%= p.target_pct %>|<%= p.walk_pct %>"><%= p.name %> (<%= p.ideal_pct %>/<%= p.target_pct %>/<%= p.walk_pct %>)</option><% }); %>
      </select>
      <span style="margin-left:auto"></span>
      <input type="text" id="presetName" placeholder="Name this preset…" style="width:170px;margin-top:0" />
      <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="savePreset()">Save current</button>
    </div>
    <div class="anchors">
      <div class="anchor ideal">
        <div class="tag"><span class="dot"></span>Ideal</div>
        <div class="pctline"><span class="pct" id="pIdeal"><%= bar.i %></span><span class="pctlab">% of each amount</span></div>
        <input type="range" min="50" max="100" value="<%= bar.i %>" id="rIdeal" name="ideal" oninput="onAnchor()" aria-label="Ideal percentage" />
        <div class="hint" id="hIdeal">The best realistic recovery you'd hope for.</div>
      </div>
      <div class="anchor target">
        <div class="tag"><span class="dot"></span>Target</div>
        <div class="pctline"><span class="pct" id="pTarget"><%= bar.t %></span><span class="pctlab">% of each amount</span></div>
        <input type="range" min="30" max="100" value="<%= bar.t %>" id="rTarget" name="target" oninput="onAnchor()" aria-label="Target percentage" />
        <div class="hint" id="hTarget">The figure you'd genuinely be happy to accept.</div>
      </div>
      <div class="anchor walk">
        <div class="tag"><span class="dot"></span>Walk-away</div>
        <div class="pctline"><span class="pct" id="pWalk"><%= bar.w %></span><span class="pctlab">% of each amount</span></div>
        <input type="range" min="10" max="100" value="<%= bar.w %>" id="rWalk" name="walk" oninput="onAnchor()" aria-label="Walk-away percentage" />
        <div class="hint" id="hWalk">The least you'll accept before escalating.</div>
      </div>
    </div>
    <div class="bidbar-foot">
      <div class="apply-to">Apply to
        <select name="scope" id="barScope">
          <option value="selected">selected cases</option>
          <option value="open" selected>all open cases</option>
          <option value="nobar">cases with no bar yet</option>
        </select>
      </div>
      <div class="note">Each case keeps its own figures, worked out from its own amount. Nothing is shared with the other side.</div>
      <button type="submit" class="bbtn bbtn-primary">Apply bid bar</button>
    </div>
  </form>
</div>

<form method="POST" action="/business/presets" id="presetForm" style="display:none">
  <input type="hidden" name="name" id="pfName" /><input type="hidden" name="ideal" id="pfI" />
  <input type="hidden" name="target" id="pfT" /><input type="hidden" name="walk" id="pfW" />
</form>

<!-- ============ TOOLBAR ============ -->
<div class="btoolbar">
  <button type="button" class="bbtn bbtn-primary bbtn-sm" onclick="openModal('newModal')">+ New dispute</button>
  <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="openImport()">⬆ Import file</button>
  <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="openModal('exportModal')">⬇ Export cases</button>
  <% if (movable) { %>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="openModal('moveModal')">⇄ Move from individual (<%= movable %>)</button>
  <% } %>
  <form method="POST" action="/business/nudge" style="display:inline">
    <input type="hidden" name="on" value="<%= nudgeOn ? '0' : '1' %>" />
    <button type="submit" class="chip-toggle <%= nudgeOn ? 'on' : '' %>"><span class="led"></span>Auto-nudge: <%= nudgeOn ? 'on · day 3 · 7 · 14' : 'off' %></button>
  </form>
  <div class="spacer"></div>
  <form method="GET" action="/business" class="searchbox">
    <input type="hidden" name="filter" value="<%= filter %>" />
    🔍 <input type="text" name="q" value="<%= q %>" placeholder="Search disputes…" />
  </form>
</div>

<!-- ============ FILTERS ============ -->
<%
  const fdefs = [['all','All open',counts.all],['attn','Needs attention',counts.attn],['awaiting','Awaiting',counts.awaiting],
                 ['converging','Converging',counts.converging],['nobar','No bid bar',counts.nobar],
                 ['noemail','No email',counts.noemail],['settled','Settled',counts.settled]];
%>
<div class="filters">
  <% fdefs.forEach(function (f) { %>
    <a class="fchip <%= f[0] === 'attn' ? 'attn' : (f[0] === 'noemail' ? 'warn' : '') %> <%= filter === f[0] ? 'on' : '' %>" href="/business?filter=<%= f[0] %><%= q ? '&q=' + encodeURIComponent(q) : '' %>"><%= f[1] %> <span class="c"><%= f[2] %></span></a>
  <% }); %>
</div>

<!-- ============ TABLE ============ -->
<%
  const ql = (q || '').toLowerCase();
  const visible = cases.filter(function (c) {
    if (ql && !((c.title + ' ' + (c.other_email || '') + ' ' + (c.our_ref || '') + ' ' + (c.category || '') + ' ' + c.id).toLowerCase().includes(ql))) return false;
    if (filter === 'all') return !['settled','declined','closed'].includes(c.status);
    if (filter === 'attn') return c.attention;
    if (filter === 'nobar') return !['settled','declined','closed'].includes(c.status) && !c.hasBar;
    if (filter === 'noemail') return !c.other_email;
    if (filter === 'declined') return c.status === 'declined';
    return c.stage === filter;
  });
%>
<form method="POST" action="/business/bulk" id="bulkForm">
  <input type="hidden" name="action" id="bulkAction" />
  <div class="btbl"><div class="btbl-scroll">
    <table class="bcases">
      <thead><tr>
        <th style="width:34px"><input type="checkbox" id="selAll" onchange="toggleAll(this.checked)" aria-label="Select all" /></th>
        <th>Debtor</th><th>Category</th><th>Email</th><th>Amount</th><th>Highest / lowest bid</th><th>Status</th>
        <th style="text-align:right">Actions</th>
      </tr></thead>
      <tbody>
      <% visible.forEach(function (c) { %>
        <tr class="<%= c.status === 'settled' ? 'settled-row' : '' %> <%= c.attention ? 'attn-row' : '' %> <%= ['settled','closed','declined'].includes(c.status) ? '' : 'clickable' %>" onclick="rowClick(event, <%= c.id %>)">
          <td><% if (!['settled','declined','closed'].includes(c.status)) { %><input type="checkbox" name="ids" value="<%= c.id %>" onchange="onSelect()" aria-label="Select <%= c.title %>" /><% } %></td>
          <td><div class="cp"><div class="nm"><%= c.title %></div><div class="rf">MB-<%= c.id %><%= c.our_ref ? ' · ' + c.our_ref : '' %><%= c.due_date ? ' · due ' + String(c.due_date).slice(0,10) : '' %></div></div></td>
          <td><% if (c.category) { %><span class="cat"><%= c.category %></span><% } else { %><span class="b-muted">—</span><% } %></td>
          <td>
            <div class="emailcell" data-id="<%= c.id %>">
              <input type="email" value="<%= c.other_email || '' %>" placeholder="add email…" class="<%= c.other_email ? '' : 'missing' %>" aria-label="Counterparty email" />
              <button type="button" onclick="saveEmail(this)">Save</button>
            </div>
          </td>
          <td class="amt"><%= money(c.amount, c.currency) %></td>
          <td class="bid">
            <% if (c.highest == null && c.lowest == null) { %><span class="none">no bids yet</span>
            <% } else { %>
              <span class="hi"><%= c.highest != null ? money(c.highest, c.currency) : '—' %></span> / <span class="lo"><%= c.lowest != null ? money(c.lowest, c.currency) : '—' %></span>
            <% } %>
          </td>
          <td>
            <%
              const pillClass = c.status === 'declined' ? 'declined' : (c.status === 'closed' ? 'closed' : c.stage);
              let pillText = STAGE_META[c.stage] ? STAGE_META[c.stage].label : c.status;
              if (c.stage === 'draft') pillText = 'Draft — not invited';
              if (c.stage === 'awaiting') pillText = 'Awaiting response';
              if (c.status === 'settled') pillText = 'Settled at ' + money(c.settled_value, c.currency);
              if (c.status === 'declined') pillText = 'Declined';
              if (c.status === 'closed') pillText = 'Closed';
            %>
            <span class="bpill <%= pillClass %>"><%= pillText %></span>
            <% if (c.stage === 'awaiting' && nudgeOn) { %><div class="tags"><span class="minitag nudge">auto-nudge</span><% if (c.stalled) { %><span class="minitag stall">stalled <%= c.age %>d</span><% } %></div><% } %>
          </td>
          <td>
            <div class="rowacts">
              <% if (c.stage === 'draft') { %>
                <button type="button" class="bbtn bbtn-primary bbtn-sm" onclick="oneAction(<%= c.id %>,'invite')" <%= c.other_email ? '' : 'disabled title="Add an email first"' %>>Invite</button>
              <% } else if (c.stage === 'awaiting') { %>
                <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="oneAction(<%= c.id %>,'remind')">Remind</button>
              <% } else if (c.stage === 'converging') { %>
                <a class="bbtn bbtn-go bbtn-sm" href="/cases/<%= c.id %>">Approve</a>
              <% } %>
              <a class="bbtn bbtn-ghost bbtn-sm" href="/cases/<%= c.id %>">Open</a>
            </div>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div></div>
  <% if (!visible.length) { %><p class="empty-note">No disputes match this view.</p><% } %>

  <div class="bulkbar" id="bulkbar">
    <span class="cnt"><span id="bulkCount">0</span> selected</span>
    <div class="spacer"></div>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="doBulk('invite')">Invite</button>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="barFromSelection()">Set bid bar</button>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="doBulk('remind')">Remind</button>
    <button type="button" class="bbtn bbtn-go bbtn-sm" onclick="openApprove()">Approve &amp; settle</button>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="if(confirm('Close the selected disputes?')) doBulk('close')">Close</button>
  </div>
</form>

<!-- hidden email form -->
<form method="POST" id="emailForm" style="display:none"><input type="hidden" name="email" id="efVal" /></form>

<!-- ============ NEW DISPUTE ============ -->
<div class="modal-bg" id="newModal">
  <div class="modal narrow">
    <button class="x" type="button" onclick="closeModal('newModal')" aria-label="Close">×</button>
    <h2>New dispute</h2>
    <p class="b-muted">Added as a draft. Nothing is sent until you invite.</p>
    <form method="POST" action="/business/new">
      <div class="frow"><label>Debtor / counterparty name</label><input type="text" name="title" required /></div>
      <div class="frow"><label>Their email <span class="b-muted" style="font-weight:400">— can be added later</span></label><input type="email" name="other_email" /></div>
      <div class="frow"><label>Amount in dispute</label><input type="number" name="amount" min="1" required /></div>
      <div class="frow"><label>Currency</label><select name="currency"><% Object.keys(CURRENCIES).forEach(function (k) { %><option value="<%= k %>"><%= CURRENCIES[k].label %></option><% }); %></select></div>
      <div class="frow"><label>Category</label><input type="text" name="category" placeholder="Unpaid Invoice, Rent Arrears…" /></div>
      <div class="frow"><label>Your case reference</label><input type="text" name="our_ref" /></div>
      <div class="frow"><label>Due date</label><input type="text" name="due_date" placeholder="2026-04-11" /></div>
      <label class="crow"><input type="checkbox" name="apply_bar" value="1" checked style="width:auto" /> Apply the current bid bar</label>
      <div class="foot">
        <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="closeModal('newModal')">Cancel</button>
        <button type="submit" class="bbtn bbtn-primary bbtn-sm">Add dispute</button>
      </div>
    </form>
  </div>
</div>

<!-- ============ IMPORT ============ -->
<div class="modal-bg" id="importModal">
  <div class="modal">
    <button class="x" type="button" onclick="closeModal('importModal')" aria-label="Close">×</button>
    <h2>Import disputes</h2>
    <div class="steps">
      <div class="step on" id="st1">1 · Choose file</div>
      <div class="step" id="st2">2 · Match columns</div>
      <div class="step" id="st3">3 · Review</div>
    </div>

    <div id="ist1">
      <div class="drop" id="drop">
        <div class="dic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4M7 9l5-5 5 5"/><path d="M4 16v3a2 2 0 002 2h12a2 2 0 002-2v-3"/></svg></div>
        <h3>Drop your spreadsheet here</h3>
        <p>.xlsx or .csv · up to 500 disputes at a time</p>
        <p style="margin-top:.7rem"><span class="bbtn bbtn-ghost bbtn-sm">Choose file</span></p>
      </div>
      <input type="file" id="fileIn" accept=".xlsx,.xls,.csv" style="display:none" />
      <p class="b-muted" style="margin-top:.8rem">Need the shape? <a href="#" onclick="downloadTemplate();return false;" style="color:#2F6BFF">Download the template</a>.</p>
    </div>

    <div id="ist2" style="display:none">
      <div class="alert ok"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg><div id="fileInfo"></div></div>
      <p class="b-muted" style="margin-bottom:.4rem">We matched these automatically. Change anything that looks wrong.</p>
      <div id="mapRows"></div>
      <div id="mapWarn"></div>
      <div class="foot"><button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="istep(1)">Back</button><button type="button" class="bbtn bbtn-primary bbtn-sm" onclick="buildReview()">Review →</button></div>
    </div>

    <div id="ist3" style="display:none">
      <p class="b-muted" style="margin-bottom:.5rem" id="revCount"></p>
      <div class="mini-tbl"><table><thead><tr><th>Debtor</th><th>Amount</th><th>Email <span style="text-transform:none;font-weight:400">(editable)</span></th></tr></thead><tbody id="revBody"></tbody></table></div>
      <div class="alert info"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg><div>Your own <b>Status</b> column is kept as <b>Source status</b> and appears in exports — but every import starts at Draft in the MidBid pipeline.</div></div>
      <label class="crow"><input type="checkbox" id="impBar" checked style="width:auto" /> Apply my current bid bar (<%= bar.i %>/<%= bar.t %>/<%= bar.w %>%) to every row</label>
      <div class="foot"><button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="istep(2)">Back</button><button type="button" class="bbtn bbtn-primary bbtn-sm" id="impGo" onclick="runImport()">Create drafts</button></div>
    </div>
  </div>
</div>

<!-- ============ EXPORT ============ -->
<div class="modal-bg" id="exportModal">
  <div class="modal">
    <button class="x" type="button" onclick="closeModal('exportModal')" aria-label="Close">×</button>
    <h2>Export cases</h2>
    <p class="b-muted">Your columns back out, plus what MidBid added.</p>
    <div style="margin-top:1rem"><b style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;color:#586079">Which cases</b>
      <div class="radio-row">
        <label><input type="radio" name="xsc" value="all" checked /> All (<%= cases.length %>)</label>
        <label><input type="radio" name="xsc" value="filtered" /> Current view (<%= visible.length %>)</label>
        <label><input type="radio" name="xsc" value="selected" /> Selected only</label>
      </div>
    </div>
    <div style="margin-top:1rem"><b style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;color:#586079">Columns</b>
      <div class="colgrid" id="colGrid"></div>
      <p class="b-muted" style="margin-top:.6rem">✦ = added by MidBid. The three bid-bar anchors stay private — only the highest and lowest bid leave.</p>
    </div>
    <div style="margin-top:1rem"><b style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;color:#586079">Format</b>
      <div class="radio-row"><label><input type="radio" name="xfm" value="xlsx" checked /> Excel (.xlsx)</label><label><input type="radio" name="xfm" value="csv" /> CSV</label></div>
    </div>
    <div class="foot"><button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="closeModal('exportModal')">Cancel</button><button type="button" class="bbtn bbtn-primary bbtn-sm" onclick="runExport()">Download</button></div>
  </div>
</div>

<!-- ============ MOVE ============ -->
<div class="modal-bg" id="moveModal">
  <div class="modal narrow">
    <button class="x" type="button" onclick="closeModal('moveModal')" aria-label="Close">×</button>
    <h2>Move cases from your individual workspace</h2>
    <p class="b-muted">Two products, two lists. Bring cases across in two deliberate steps.</p>
    <div class="alert info"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
      <div><b>They move, they don't copy.</b> A dispute that's already been invited keeps its history, its bids and its link — it just changes workspace. The other side sees nothing and gets no second invitation. Settled cases stay where they are.</div>
    </div>
    <p style="font-size:.9rem;margin-top:1rem"><b>Step 1.</b> Download your individual cases.<br />
      <a class="bbtn bbtn-ghost bbtn-sm" href="/dashboard" style="margin-top:.5rem">Go to my cases →</a>
      <span class="b-muted" style="display:block;margin-top:.4rem">Use "Download my cases" there — <%= movable %> can move.</span>
    </p>
    <p style="font-size:.9rem;margin-top:1.2rem"><b>Step 2.</b> Upload that file back here.</p>
    <div class="drop" id="mdrop" style="padding:22px;margin-top:.5rem">
      <h3 style="font-size:1rem">Drop the file to move them across</h3>
      <p>We read the MidBid case IDs from it</p>
    </div>
    <input type="file" id="mfileIn" accept=".xlsx,.xls,.csv" style="display:none" />
    <div id="moveOut"></div>
  </div>
</div>

<!-- ============ PER-CASE BID BAR ============ -->
<div class="modal-bg" id="caseModal">
  <div class="modal narrow">
    <button class="x" type="button" onclick="closeModal('caseModal')" aria-label="Close">&times;</button>
    <h2 id="cmTitle">Case</h2>
    <p class="b-muted" id="cmSub"></p>

    <form method="POST" id="cmForm">
      <div class="anchors" style="grid-template-columns:repeat(3,1fr)">
        <div class="anchor ideal">
          <div class="tag"><span class="dot"></span>Ideal</div>
          <div class="pctline"><span class="pct" id="cmPI">95</span><span class="pctlab">%</span></div>
          <input type="range" min="50" max="100" value="95" id="cmRI" name="ideal" oninput="cmAnchor()" aria-label="Ideal percentage" />
          <div class="cm-amt" id="cmVI">&mdash;</div>
        </div>
        <div class="anchor target">
          <div class="tag"><span class="dot"></span>Target</div>
          <div class="pctline"><span class="pct" id="cmPT">80</span><span class="pctlab">%</span></div>
          <input type="range" min="30" max="100" value="80" id="cmRT" name="target" oninput="cmAnchor()" aria-label="Target percentage" />
          <div class="cm-amt" id="cmVT">&mdash;</div>
        </div>
        <div class="anchor walk">
          <div class="tag"><span class="dot"></span>Walk-away</div>
          <div class="pctline"><span class="pct" id="cmPW">65</span><span class="pctlab">%</span></div>
          <input type="range" min="10" max="100" value="65" id="cmRW" name="walk" oninput="cmAnchor()" aria-label="Walk-away percentage" />
          <div class="cm-amt" id="cmVW">&mdash;</div>
        </div>
      </div>

      <div class="cscale">
        <div class="ct" id="cmTrack">
          <div class="cband" id="cmBand"></div>
          <div class="cm w" id="cmMW"></div>
          <div class="cm t" id="cmMT"></div>
          <div class="cm i" id="cmMI"></div>
          <div class="cr" id="cmResp" style="display:none"></div>
        </div>
        <div class="cax"><span>0</span><span id="cmMax"></span></div>
        <p class="cnote" id="cmNote"></p>
      </div>

      <div class="foot">
        <a class="bbtn bbtn-ghost bbtn-sm" id="cmOpen" href="#">Open full case</a>
        <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="closeModal('caseModal')">Cancel</button>
        <button type="submit" class="bbtn bbtn-primary bbtn-sm">Save this case's bar</button>
      </div>
    </form>
  </div>
</div>

<!-- ============ APPROVE ============ -->
<div class="modal-bg" id="approveModal">
  <div class="modal narrow">
    <button class="x" type="button" onclick="closeModal('approveModal')" aria-label="Close">×</button>
    <h2>Approve &amp; settle</h2>
    <p class="b-muted">Approving is binding. Only the selected cases already in the settle band are approved — the rest are skipped.</p>
    <div class="mini-tbl" style="margin-top:.7rem"><table><tbody id="approveList"></tbody></table></div>
    <div class="foot"><button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="closeModal('approveModal')">Cancel</button><button type="button" class="bbtn bbtn-go bbtn-sm" id="approveGo" onclick="doBulk('approve')">Approve these</button></div>
  </div>
</div>

<script>
var BAND = <%- JSON.stringify(cases.filter(function (c) { return c.stage === 'converging'; }).map(function (c) { return { id: c.id, t: c.title }; })) %>;
var ALL = <%- JSON.stringify(cases.map(function (c) { return {
  id: c.id, our_ref: c.our_ref, title: c.title, creditor: (me.company_name || me.name),
  email: c.other_email, category: c.category, secondary_ref: c.secondary_ref,
  amount: c.amount, currency: c.currency, issue_date: c.issue_date ? String(c.issue_date).slice(0,10) : '',
  due_date: c.due_date ? String(c.due_date).slice(0,10) : '', source_status: c.source_status,
  stage: c.stage, highest: c.highest, lowest: c.lowest, settled: c.settled_value,
  ideal: c.claim_ideal, target: c.claim_fair, walk: c.claim_value, status: c.status,
  settled_at: c.settled_at ? String(c.settled_at).slice(0,10) : '', notes: c.notes
}; })) %>;
var VISIBLE_IDS = <%- JSON.stringify(visible.map(function (c) { return c.id; })) %>;

/* ---------- bid bar ---------- */
var HINTS={ideal:['A firm opening — little room to move.',"The best realistic recovery you'd hope for.",'Ambitious. Signals confidence in the claim.'],
 target:["The figure you'd genuinely accept.",'A fair middle most cases settle around.','Reasonable — likely to land a deal.'],
 walk:["The least you'll accept before escalating.",'A cautious floor — protects you late on.','Low floor: quicker deals, smaller recovery.']};
function pickHint(k,v){var a=HINTS[k];return v>=85?a[2]:(v>=60?a[1]:a[0]);}
function onAnchor(){
  var i=+rIdeal.value,t=+rTarget.value,w=+rWalk.value;
  if(t>i){t=i;rTarget.value=i;} if(w>t){w=t;rWalk.value=t;}
  pIdeal.textContent=i;pTarget.textContent=t;pWalk.textContent=w;
  hIdeal.textContent=pickHint('ideal',i);hTarget.textContent=pickHint('target',t);hWalk.textContent=pickHint('walk',w);
}
function loadPreset(){var v=document.getElementById('presetSel').value;if(v==='-1')return;var p=v.split('|');rIdeal.value=p[0];rTarget.value=p[1];rWalk.value=p[2];onAnchor();}
function savePreset(){var nm=(document.getElementById('presetName').value||'').trim();if(!nm){alert('Give the preset a name first.');return;}
  document.getElementById('pfName').value=nm;document.getElementById('pfI').value=rIdeal.value;
  document.getElementById('pfT').value=rTarget.value;document.getElementById('pfW').value=rWalk.value;
  document.getElementById('presetForm').submit();}

/* ---------- selection ---------- */
function checks(){return [].slice.call(document.querySelectorAll('#bulkForm input[name=ids]'));}
function selected(){return checks().filter(function(c){return c.checked;});}
function onSelect(){checks().forEach(function(cb){cb.closest('tr').classList.toggle('sel',cb.checked);});
  var n=selected().length;document.getElementById('bulkCount').textContent=n;
  document.getElementById('bulkbar').classList.toggle('show',n>0);}
function toggleAll(on){checks().forEach(function(cb){cb.checked=on;});onSelect();}
function doBulk(a){if(!selected().length){alert('Nothing selected.');return;}
  document.getElementById('bulkAction').value=a;document.getElementById('bulkForm').submit();}
function oneAction(id,a){checks().forEach(function(cb){cb.checked=(+cb.value===id);});doBulk(a);}
function barFromSelection(){var f=document.getElementById('barForm');
  [].slice.call(f.querySelectorAll('input[name=ids]')).forEach(function(n){n.remove();});
  selected().forEach(function(cb){var h=document.createElement('input');h.type='hidden';h.name='ids';h.value=cb.value;f.appendChild(h);});
  document.getElementById('barScope').value='selected';f.scrollIntoView({behavior:'smooth',block:'center'});}

/* ---------- editable email ---------- */
document.querySelectorAll('.emailcell input').forEach(function(inp){
  inp.addEventListener('input',function(){inp.closest('.emailcell').classList.add('dirty');});
  inp.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();saveEmail(inp.nextElementSibling);}});
});
function saveEmail(btn){
  var cell=btn.closest('.emailcell');
  var val=cell.querySelector('input').value.trim();
  var f=document.getElementById('emailForm');
  f.action='/business/cases/'+cell.dataset.id+'/email';
  document.getElementById('efVal').value=val;
  f.submit();
}

/* ---------- modals ---------- */
function openModal(id){document.getElementById(id).classList.add('show');}
function closeModal(id){document.getElementById(id).classList.remove('show');}
function openApprove(){
  var picked=selected().map(function(c){return +c.value;});
  var elig=BAND.filter(function(b){return picked.indexOf(b.id)>-1;});
  var list=document.getElementById('approveList'),go=document.getElementById('approveGo');
  if(!elig.length){list.innerHTML='<tr><td class="b-muted">None of the selected cases are in the settle band yet.</td></tr>';go.style.display='none';}
  else{list.innerHTML=elig.map(function(b){return '<tr><td><b>'+b.t+'</b> · MB-'+b.id+'</td></tr>';}).join('');go.style.display='';}
  openModal('approveModal');
}

/* ---------- import ---------- */
var TARGETS=[['','Ignore this column'],['title','Debtor / counterparty — required'],['email','Counterparty email'],
 ['amount','Amount in dispute — required'],['currency','Currency'],['our_ref','Your case reference'],
 ['secondary_ref','Secondary reference'],['category','Category'],['source_status','Source status'],
 ['issue_date','Issue date'],['due_date','Due date'],['notes','Notes']];
var HEADERS=[],ROWS=[],MAPPING=[];

function guess(h){
  var s=(h||'').toLowerCase();
  if(s.indexOf('email')>-1) return 'email';
  if(s.indexOf('debtor')>-1||s.indexOf('counterparty')>-1||(s.indexOf('company')>-1&&s.indexOf('creditor')<0)) return 'title';
  if(s.indexOf('amount')>-1||s.indexOf('owed')>-1||s.indexOf('value')>-1) return 'amount';
  if(s.indexOf('currency')>-1) return 'currency';
  if(s.indexOf('case id')>-1||s==='case_id'||s==='id') return 'our_ref';
  if(s.indexOf('reference')>-1||s.indexOf('ref')>-1) return 'secondary_ref';
  if(s.indexOf('category')>-1||s.indexOf('type')>-1) return 'category';
  if(s.indexOf('status')>-1) return 'source_status';
  // Notes before dates: "Notes of Claim / Dues" contains "due".
  if(s.indexOf('note')>-1||s.indexOf('description')>-1||s.indexOf('comment')>-1) return 'notes';
  if(s.indexOf('issue')>-1&&s.indexOf('date')>-1) return 'issue_date';
  if(s.indexOf('due')>-1&&s.indexOf('date')>-1) return 'due_date';
  if(s==='issued'||s==='issue') return 'issue_date';
  if(s==='due') return 'due_date';
  return '';
}
function openImport(){istep(1);openModal('importModal');}
function istep(n){
  [1,2,3].forEach(function(i){
    document.getElementById('ist'+i).style.display=(i===n)?'block':'none';
    var s=document.getElementById('st'+i);s.classList.toggle('on',i===n);s.classList.toggle('done',i<n);
  });
}
document.getElementById('drop').addEventListener('click',function(){document.getElementById('fileIn').click();});
document.getElementById('fileIn').addEventListener('change',function(e){if(e.target.files[0])readFile(e.target.files[0]);});
['dragover','dragleave','drop'].forEach(function(ev){
  var d=document.getElementById('drop');
  d.addEventListener(ev,function(e){e.preventDefault();d.classList.toggle('hot',ev==='dragover');
    if(ev==='drop'&&e.dataTransfer.files[0])readFile(e.dataTransfer.files[0]);});
});
function readFile(file){
  var r=new FileReader();
  r.onload=function(e){
    try{
      var wb=XLSX.read(e.target.result,{type:'array'});
      var ws=wb.Sheets[wb.SheetNames[0]];
      var grid=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
      grid=grid.filter(function(r){return r.some(function(c){return String(c).trim()!=='';});});
      if(grid.length<2){alert('That sheet looks empty.');return;}
      HEADERS=grid[0].map(function(h){return String(h).trim();});
      ROWS=grid.slice(1);
      MAPPING=HEADERS.map(guess);
      document.getElementById('fileInfo').innerHTML='<b>'+file.name+'</b> — sheet "'+wb.SheetNames[0]+'" · '+ROWS.length+' rows · '+HEADERS.length+' columns';
      renderMap();
      istep(2);
    }catch(err){alert('Could not read that file: '+err.message);}
  };
  r.readAsArrayBuffer(file);
}
function renderMap(){
  document.getElementById('mapRows').innerHTML=HEADERS.map(function(h,i){
    return '<div class="maprow"><span class="srccol" title="'+h+'">'+h+'</span><span class="arrw">→</span>'+
      '<select onchange="MAPPING['+i+']=this.value;checkMap()">'+TARGETS.map(function(t){
        return '<option value="'+t[0]+'"'+(MAPPING[i]===t[0]?' selected':'')+'>'+t[1]+'</option>';
      }).join('')+'</select></div>';
  }).join('');
  checkMap();
}
function checkMap(){
  var w=document.getElementById('mapWarn'),msgs=[];
  if(MAPPING.indexOf('title')<0) msgs.push('No column is mapped to <b>Debtor / counterparty</b> — that is required.');
  if(MAPPING.indexOf('amount')<0) msgs.push('No column is mapped to <b>Amount in dispute</b> — that is required.');
  if(MAPPING.indexOf('email')<0) msgs.push('<b>Your sheet has no email column.</b> These will import as drafts, but nothing can be invited until you add an address — you can type them in on the next step, or in the list afterwards.');
  w.innerHTML=msgs.length?'<div class="alert warn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01M10.3 3.9L1.8 18a2 2 0 001.7 3h17a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/></svg><div>'+msgs.join('<br />')+'</div></div>':'';
}
function mapped(){
  return ROWS.map(function(r){
    var o={};
    MAPPING.forEach(function(t,i){ if(t) o[t]=r[i]; });
    return o;
  }).filter(function(o){return String(o.title||'').trim() && String(o.amount||'').replace(/[^0-9]/g,'');});
}
var PARSED=[];
function buildReview(){
  if(MAPPING.indexOf('title')<0||MAPPING.indexOf('amount')<0){alert('Map the required columns first.');return;}
  PARSED=mapped();
  document.getElementById('revCount').innerHTML='<b>'+PARSED.length+' dispute'+(PARSED.length===1?'':'s')+' ready.</b> Everything arrives as a Draft — nothing is sent until you invite. Add any missing emails now or later.';
  document.getElementById('revBody').innerHTML=PARSED.map(function(p,i){
    var em=(p.email||'').trim();
    return '<tr><td><b>'+String(p.title)+'</b></td><td>'+String(p.amount)+'</td>'+
      '<td><input type="email" value="'+em+'" placeholder="add email…" class="'+(em?'':'missing')+'" onchange="PARSED['+i+'].email=this.value;this.classList.toggle(\'missing\',!this.value)" /></td></tr>';
  }).join('');
  istep(3);
}
function runImport(){
  var btn=document.getElementById('impGo');
  btn.disabled=true;btn.textContent='Creating…';
  fetch('/business/import',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({rows:PARSED,apply_bar:document.getElementById('impBar').checked})})
    .then(function(r){return r.json();})
    .then(function(d){ window.location='/business?msg='+encodeURIComponent(d.msg||'Imported.'); })
    .catch(function(){ btn.disabled=false;btn.textContent='Create drafts';alert('Import failed. Please try again.'); });
}
function downloadTemplate(){
  var ws=XLSX.utils.aoa_to_sheet([['Debtor Company','Debtor Email','Category','Case ID','Reference No.','Amount Owed','Currency','Issue Date','Due Date','Status','Notes'],
    ['Company A Ltd','ap@company-a.co.uk','Unpaid Invoice','INV-1001','REF-2026100',2500,'GBP','2026-01-01','2026-04-11','Pending','Unpaid invoice for consulting services.']]);
  var wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'Disputes');
  XLSX.writeFile(wb,'midbid-import-template.xlsx');
}

/* ---------- export ---------- */
var COLS=[['our_ref','Case ID',0],['title','Debtor Company',0],['creditor','Creditor',0],['category','Category',0],
 ['secondary_ref','Reference No.',0],['email','Debtor Email',0],['amount','Amount Owed',0],['currency','Currency',0],
 ['issue_date','Issue Date',0],['due_date','Due Date',0],['source_status','Source status',0],['notes','Notes',0],
 ['id','MidBid case ID',1],['stage','MidBid status',1],['highest','Highest bid',1],['lowest','Lowest bid',1],
 ['settled','Settled amount',1],['settled_at','Date settled',1]];
document.getElementById('colGrid').innerHTML=COLS.map(function(c,i){
  return '<label class="colchk '+(c[2]?'new':'')+'"><input type="checkbox" data-i="'+i+'" '+(c[0]==='settled_at'?'':'checked')+' /> '+c[1]+(c[2]?' ✦':'')+'</label>';
}).join('');
function runExport(){
  var scope=document.querySelector('input[name=xsc]:checked').value;
  var fmt=document.querySelector('input[name=xfm]:checked').value;
  var picked=selected().map(function(c){return +c.value;});
  var rows=ALL.filter(function(r){
    if(scope==='filtered') return VISIBLE_IDS.indexOf(r.id)>-1;
    if(scope==='selected') return picked.indexOf(r.id)>-1;
    return true;
  });
  if(!rows.length){alert('Nothing to export in that scope.');return;}
  var cols=[].slice.call(document.querySelectorAll('#colGrid input:checked')).map(function(cb){return COLS[+cb.dataset.i];});
  if(!cols.length){alert('Pick at least one column.');return;}
  var out=rows.map(function(r){
    var o={};
    cols.forEach(function(c){ var v=r[c[0]]; o[c[1]]=(v===null||v===undefined)?'':v; });
    return o;
  });
  var ws=XLSX.utils.json_to_sheet(out,{header:cols.map(function(c){return c[1];})});
  var wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'Disputes');
  XLSX.writeFile(wb,'midbid-disputes.'+(fmt==='csv'?'csv':'xlsx'),{bookType:fmt==='csv'?'csv':'xlsx'});
  closeModal('exportModal');
}

/* ---------- move ---------- */
var md=document.getElementById('mdrop');
if(md){
  md.addEventListener('click',function(){document.getElementById('mfileIn').click();});
  document.getElementById('mfileIn').addEventListener('change',function(e){if(e.target.files[0])readMove(e.target.files[0]);});
  ['dragover','dragleave','drop'].forEach(function(ev){
    md.addEventListener(ev,function(e){e.preventDefault();md.classList.toggle('hot',ev==='dragover');
      if(ev==='drop'&&e.dataTransfer.files[0])readMove(e.dataTransfer.files[0]);});
  });
}
function readMove(file){
  var r=new FileReader();
  r.onload=function(e){
    try{
      var wb=XLSX.read(e.target.result,{type:'array'});
      var rows=XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{defval:''});
      var key=null;
      if(rows.length) Object.keys(rows[0]).forEach(function(k){
        var s=k.toLowerCase();
        if(s.indexOf('midbid')>-1&&s.indexOf('id')>-1) key=k;
      });
      if(!key){document.getElementById('moveOut').innerHTML='<div class="alert warn"><div>No <b>MidBid case ID</b> column in that file. Download your cases from the individual dashboard and upload that file unchanged.</div></div>';return;}
      var ids=rows.map(function(x){return parseInt(x[key],10);}).filter(Boolean);
      if(!ids.length){document.getElementById('moveOut').innerHTML='<div class="alert warn"><div>No case IDs found in that file.</div></div>';return;}
      fetch('/business/move-in',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({caseIds:ids})})
        .then(function(r){return r.json();})
        .then(function(d){ window.location='/business?msg='+encodeURIComponent(d.msg||'Done.'); });
    }catch(err){document.getElementById('moveOut').innerHTML='<div class="alert warn"><div>Could not read that file: '+err.message+'</div></div>';}
  };
  r.readAsArrayBuffer(file);
}

/* ---------- per-case bid bar ---------- */
var SYM = <%- JSON.stringify(Object.keys(CURRENCIES).reduce(function(a,k){a[k]=CURRENCIES[k].symbol;return a;},{})) %>;
var CM = null;
function m(n,c){ return (SYM[c]||'\u00a3') + Math.round(n).toLocaleString('en-GB'); }

// Clicking the row opens this case's own bar — but never when the click was
// meant for a control inside the row.
function rowClick(e, id){
  if (e.target.closest('input, button, a, label, .emailcell')) return;
  openCase(id);
}
function openCase(id){
  var c = null;
  for (var i=0;i<ALL.length;i++) if (ALL[i].id===id) c = ALL[i];
  if (!c) return;
  CM = c;
  document.getElementById('cmTitle').textContent = c.title;
  document.getElementById('cmSub').innerHTML = m(c.amount, c.currency) + ' in dispute · MB-' + c.id +
    (c.our_ref ? ' · ' + c.our_ref : '') + ' — <b>set this case on its own</b>, without touching the other cases.';
  document.getElementById('cmForm').action = '/business/cases/' + c.id + '/anchors';
  document.getElementById('cmOpen').href = '/cases/' + c.id;
  document.getElementById('cmMax').textContent = m(c.amount, c.currency);
  // Start from this case's own figures if it has them, else the group bar.
  var pc = function(v){ return v==null ? null : Math.round(v / c.amount * 100); };
  document.getElementById('cmRI').value = pc(c.ideal)  != null ? pc(c.ideal)  : <%= bar.i %>;
  document.getElementById('cmRT').value = pc(c.target) != null ? pc(c.target) : <%= bar.t %>;
  document.getElementById('cmRW').value = pc(c.walk)   != null ? pc(c.walk)   : <%= bar.w %>;
  cmAnchor();
  openModal('caseModal');
}
function cmAnchor(){
  if (!CM) return;
  var ri=document.getElementById('cmRI'), rt=document.getElementById('cmRT'), rw=document.getElementById('cmRW');
  var i=+ri.value, t=+rt.value, w=+rw.value;
  if (t>i){ t=i; rt.value=i; } if (w>t){ w=t; rw.value=t; }
  document.getElementById('cmPI').textContent=i;
  document.getElementById('cmPT').textContent=t;
  document.getElementById('cmPW').textContent=w;
  var vi=CM.amount*i/100, vt=CM.amount*t/100, vw=CM.amount*w/100;
  document.getElementById('cmVI').innerHTML=m(vi,CM.currency)+' <span class="p">at '+i+'%</span>';
  document.getElementById('cmVT').innerHTML=m(vt,CM.currency)+' <span class="p">at '+t+'%</span>';
  document.getElementById('cmVW').innerHTML=m(vw,CM.currency)+' <span class="p">at '+w+'%</span>';
  document.getElementById('cmMI').style.left=i+'%';
  document.getElementById('cmMT').style.left=t+'%';
  document.getElementById('cmMW').style.left=w+'%';
  var band=document.getElementById('cmBand');
  band.style.left=w+'%'; band.style.right=(100-i)+'%';
  // Where the other side actually is, if they have bid.
  var resp=document.getElementById('cmResp'), note=document.getElementById('cmNote');
  if (CM.lowest != null){
    var rp = Math.max(0, Math.min(100, CM.lowest / CM.amount * 100));
    resp.style.display=''; resp.style.left=rp+'%';
    var close = (vw - CM.lowest) <= 0.10*CM.amount;
    band.classList.toggle('lit', close);
    note.innerHTML = close
      ? 'They are at ' + m(CM.lowest,CM.currency) + '. <b>Your walk-away is within reach — this one can settle.</b>'
      : 'They are at ' + m(CM.lowest,CM.currency) + ', ' + m(vw-CM.lowest,CM.currency) + ' below your walk-away.';
  } else {
    resp.style.display='none'; band.classList.remove('lit');
    note.textContent = CM.stage === 'draft' ? 'Not invited yet — they have not bid.' : 'They have not bid yet.';
  }
}

onAnchor(); onSelect();
</script>


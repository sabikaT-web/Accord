<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Business dashboard — MidBid</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;500;600&family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<header class="bar"><div class="business-wrap bar-in">
  <a class="brand" href="/business">MidBid Business</a>
  <div class="bar-right"><a href="/dashboard">Individual portal</a><form method="post" action="/logout"><button class="linkbtn">Log out</button></form></div>
</div></header>
<main class="business-main"><div class="business-wrap">
  <div class="business-heading"><div><h1 class="page">Business dashboard</h1><p class="sub">Import disputes, complete missing emails, invite counterparties and export your live case ledger.</p></div></div>
  <% if (flash) { %><div class="banner"><%= flash %></div><% } %>

  <section class="business-kpis">
    <div class="kpi"><span>Total in dispute</span><strong><%= money(kpis.totalInDispute, kpis.currency) %></strong><small>Across open cases</small></div>
    <div class="kpi"><span>Respondent join rate</span><strong><%= kpis.joinRate %>%</strong><small>Of invited counterparties</small></div>
    <div class="kpi"><span>Converging</span><strong><%= kpis.inBand %></strong><small>Cases within reach</small></div>
    <div class="kpi"><span>Recovered</span><strong><%= money(kpis.settledValue, kpis.currency) %></strong><small>Settled value</small></div>
  </section>

  <section class="card">
    <div class="section-head"><div><h2>Import a spreadsheet</h2><p class="muted">Upload Excel or CSV. The debtor email column is optional and remains editable after import.</p></div><a class="btn btn-ghost" href="/midbid-import-template.xlsx" download>Download template</a></div>
    <form method="post" action="/business/import" enctype="multipart/form-data" class="import-form">
      <label class="dropzone"><input type="file" name="spreadsheet" accept=".xlsx,.xls,.csv" required><b>Choose an Excel or CSV file</b><span>Up to 500 rows and 8 MB</span></label>
      <label class="checkline"><input type="checkbox" name="apply_bar" value="1" checked> Apply my current bid bar (<%= bar.i %> / <%= bar.t %> / <%= bar.w %>%)</label>
      <button class="btn btn-primary" type="submit">Import as drafts</button>
    </form>
  </section>

  <section class="card">
    <div class="section-head"><div><h2>Pipeline</h2><p class="muted">Click a stage to filter your cases.</p></div><a class="btn btn-ghost" href="/business/export.xlsx">Export Excel</a></div>
    <nav class="pipeline">
      <% ['all','draft','awaiting','progress','converging','settled'].forEach(function(s){ %>
        <a class="pipe-step <%= filter===s ? 'on' : '' %>" href="/business?filter=<%= s %>"><span><%= s==='all'?'Open':s %></span><b><%= counts[s] || 0 %></b></a>
      <% }) %>
    </nav>
  </section>

  <section class="card">
    <div class="section-head"><div><h2>Your cases</h2><p class="muted">Drafts without an email are kept safely but cannot be invited.</p></div></div>
    <form method="post" action="/business/bulk">
      <div class="bulkbar"><select name="action"><option value="invite">Invite selected</option><option value="remind">Remind selected</option><option value="approve">Approve selected</option><option value="close">Close selected</option></select><button class="btn btn-primary" type="submit">Apply</button></div>
      <div class="table-scroll"><table class="business-table"><thead><tr><th><input type="checkbox" id="allCases"></th><th>Debtor / email</th><th>Category / reference</th><th>Amount</th><th>Highest / lowest bid</th><th>Status</th><th>Email action</th></tr></thead><tbody>
      <% const visible = cases.filter(function(c){ return filter==='all' ? !['settled','declined','closed'].includes(c.status) : c.stage===filter; }); %>
      <% if (!visible.length) { %><tr><td colspan="7" class="empty">No cases in this view.</td></tr><% } %>
      <% visible.forEach(function(c){ const vals=[c.claim_ideal,c.claim_fair,c.claim_value,c.resp_ideal,c.resp_fair,c.resp_value].filter(v=>v!=null); const hi=vals.length?Math.max.apply(null,vals):null; const lo=vals.length?Math.min.apply(null,vals):null; %>
        <tr>
          <td><input class="caseCheck" type="checkbox" name="ids" value="<%= c.id %>"></td>
          <td><b><%= c.title %></b><div class="muted"><%= c.other_email || 'Email missing' %></div></td>
          <td><span class="cat"><%= c.category || 'Uncategorised' %></span><div class="muted"><%= c.our_ref || 'No reference' %></div></td>
          <td><b><%= money(c.amount,c.currency) %></b><div class="muted"><%= c.due_date ? 'Due '+fmtDay(c.due_date) : 'No due date' %></div></td>
          <td><%= hi==null ? 'No bids yet' : money(hi,c.currency)+' / '+money(lo,c.currency) %></td>
          <td><span class="pill <%= c.stage==='settled'?'settled':'active' %>"><%= c.stage %></span></td>
          <td>
            <form method="post" action="/business/cases/<%= c.id %>/email" class="email-edit">
              <input type="email" name="other_email" value="<%= c.other_email || '' %>" placeholder="debtor@example.com">
              <button class="btn btn-ghost" type="submit">Save</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody></table></div>
    </form>
  </section>
</div></main>
<script>
const all=document.getElementById('allCases'); if(all) all.addEventListener('change',()=>document.querySelectorAll('.caseCheck').forEach(c=>c.checked=all.checked));
</script>
</body></html>

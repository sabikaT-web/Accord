<%
  // ---- Trends -----------------------------------------------------------------
  // Computed from the real timestamps already on each case, so the sparklines and
  // deltas are honest rather than decorative. Once you have months of history they
  // simply get richer; nothing here needs changing.
  const WEEKS = 8;
  const now = Date.now(), WEEK = 7 * 86400000;
  const edges = [];
  for (let k = WEEKS - 1; k >= 0; k--) edges.push(now - k * WEEK);
  const createdBy = (c, t) => new Date(c.created_at).getTime() <= t;
  const settledBy = (c, t) => c.settled_at && new Date(c.settled_at).getTime() <= t;

  const sInDispute = edges.map(t => cases.filter(c => createdBy(c, t) && !settledBy(c, t) && !['closed','declined'].includes(c.status)).reduce((a, c) => a + c.amount, 0));
  const sSettled  = edges.map(t => cases.filter(c => settledBy(c, t)).reduce((a, c) => a + (c.settled_value || 0), 0));
  const sJoin = edges.map(t => {
    const inv = cases.filter(c => createdBy(c, t) && c.stage !== 'draft');
    const jn = inv.filter(c => ['progress','converging','settled'].includes(c.stage) || c.status === 'declined');
    return inv.length ? Math.round(jn.length / inv.length * 100) : 0;
  });
  const sBand = edges.map(t => cases.filter(c => createdBy(c, t) && c.stage === 'converging').length);

  const delta = (arr) => { const a = arr[arr.length - 1], b = arr[Math.max(0, arr.length - 5)]; return a - b; };
  const cur = kpis.currency;

  const STAGE_META = {
    draft:      { label: 'Draft',       color: '#B4B2A9' },
    awaiting:   { label: 'Awaiting',    color: '#F5B312' },
    progress:   { label: 'In progress', color: '#2F6BFF' },
    converging: { label: 'Converging',  color: '#16306B' },
    settled:    { label: 'Settled',     color: '#15B877' }
  };

  function sparkPts(points) {
    const w = 100, h = 28;
    const max = Math.max.apply(null, points), min = Math.min.apply(null, points);
    const range = (max - min) || 1;
    return points.map((p, i) => {
      const x = (i / (points.length - 1)) * w;
      const y = h - 2 - ((p - min) / range) * (h - 4);
      return x.toFixed(1) + ',' + y.toFixed(1);
    }).join(' ');
  }
%>
<%- include('partials/head', { pageHead: {
     eyebrow: 'Business portal',
     title: 'Your disputes',
     sub: 'Bring them in, set your position once, invite the other side, and let MidBid chase the ones that go quiet.'
   } }) %>

<style>
/* Scoped to the business portal so styles.css needs no changes. */
.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:-44px 0 22px;position:relative;z-index:5}
.kpi{background:#fff;border:1px solid #DCE3EF;border-radius:14px;padding:16px 16px 12px;text-decoration:none;color:inherit;display:block}
a.kpi{transition:border-color .15s,transform .15s}
a.kpi:hover{border-color:#2F6BFF;transform:translateY(-2px);text-decoration:none}
a.kpi.on{border-color:#16306B;box-shadow:inset 0 0 0 1px #16306B}
.kpi-label{font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;color:#586079;font-weight:700}
.kpi-num{font-family:"Fraunces",Georgia,serif;font-weight:500;font-size:1.8rem;line-height:1.1;margin-top:.35rem}
.kpi-delta{font-size:.75rem;font-weight:600;margin-top:.2rem}
.kpi-delta .sub{color:#586079;font-weight:500}
.kpi-delta.up{color:#1c5e3f}.kpi-delta.down{color:#8a3d1a}.kpi-delta.flat{color:#586079}
.kpi-spark{margin-top:8px;display:block;width:100%;height:28px}

.bcard{background:#fff;border:1px solid #DCE3EF;border-radius:14px;padding:22px;margin-bottom:18px}
.ov-head{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:16px}
.ov-title{font-family:"Fraunces",Georgia,serif;font-weight:500;font-size:1.25rem}
.b-muted{color:#586079;font-size:.9rem}

.path{display:flex;align-items:stretch;flex-wrap:wrap}
.pathstep{flex:1;min-width:118px;background:#EEF2F8;color:#1E2A45;padding:12px 16px 12px 32px;margin-left:-14px;display:flex;flex-direction:column;justify-content:center;text-decoration:none;transition:background .15s;clip-path:polygon(16px 50%,0 0,calc(100% - 16px) 0,100% 50%,calc(100% - 16px) 100%,0 100%)}
.pathstep:first-child{margin-left:0;padding-left:18px;clip-path:polygon(0 0,calc(100% - 16px) 0,100% 50%,calc(100% - 16px) 100%,0 100%)}
.pathstep:last-child{clip-path:polygon(16px 50%,0 0,100% 0,100% 100%,0 100%)}
.pathstep:hover{background:#E2E9F5;text-decoration:none}
.pathstep.on{background:#16306B;color:#fff}
.ps-name{font-size:.8rem;font-weight:600;display:flex;align-items:center;white-space:nowrap}
.ps-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:6px;flex:none}
.ps-count{font-family:"Spline Sans Mono",monospace;font-weight:700;font-size:1.15rem;margin-top:.15rem}
.path-extra{margin-top:14px;display:flex;gap:.7rem;align-items:center;flex-wrap:wrap}
.declined-chip{display:inline-flex;align-items:center;background:#fbeae2;border:1px solid #e6b39a;color:#8a3d1a;border-radius:999px;padding:.34em .8em;font-size:.82rem;font-weight:600;text-decoration:none}
.declined-chip.on{background:#8a3d1a;border-color:#8a3d1a;color:#fff}

.bidbar-head{display:flex;align-items:center;gap:.7rem;margin-bottom:4px}
.bidbar-head .ic{width:34px;height:34px;border-radius:9px;flex:none;display:flex;align-items:center;justify-content:center;background:rgba(47,107,255,.1);color:#2F6BFF}
.preset-row{display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;margin:14px 0 4px}
.preset-row label{font-size:.82rem;font-weight:700;color:#586079}
.preset-row select,.preset-row input[type=text]{border:1px solid #DCE3EF;border-radius:9px;padding:.44em .7em;font:inherit;font-size:.86rem;background:#fff;color:#1E2A45}
.anchors{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:14px 0 6px}
.anchor{border:1px solid #DCE3EF;border-radius:12px;padding:14px}
.anchor .tag{font-size:.74rem;font-weight:700;letter-spacing:.03em;text-transform:uppercase;display:flex;align-items:center;gap:.4em}
.anchor .tag .dot{width:9px;height:9px;border-radius:50%}
.anchor.ideal .dot{background:#15B877}.anchor.ideal .tag{color:#1c5e3f}
.anchor.target .dot{background:#2F6BFF}.anchor.target .tag{color:#2F6BFF}
.anchor.walk .dot{background:#F5B312}.anchor.walk .tag{color:#B5790F}
.anchor .pctline{display:flex;align-items:baseline;gap:.3em;margin:.5rem 0 .2rem}
.anchor .pct{font-family:"Fraunces",Georgia,serif;font-size:1.9rem;font-weight:500}
.anchor .pctlab{font-size:.85rem;color:#586079}
.anchor input[type=range]{width:100%;accent-color:#2F6BFF;margin-top:.3rem}
.anchor .hint{font-size:.78rem;color:#586079;margin-top:.3rem;min-height:2.4em}
.bidbar-foot{display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-top:14px;padding-top:16px;border-top:1px dashed #DCE3EF}
.apply-to{display:flex;align-items:center;gap:.5em;font-size:.86rem;color:#586079}
.apply-to select{border:1px solid #DCE3EF;border-radius:9px;padding:.4em .7em;font:inherit;font-size:.86rem;background:#fff;color:#1E2A45}
.bidbar-foot .note{font-size:.8rem;color:#586079;flex:1;min-width:200px}

.btoolbar{display:flex;align-items:center;gap:.7rem;flex-wrap:wrap;margin-bottom:14px}
.btoolbar .spacer{flex:1}
.bbtn{display:inline-flex;align-items:center;gap:.5em;font:inherit;font-weight:600;font-size:.92rem;padding:.62em 1.15em;border-radius:999px;border:1px solid transparent;cursor:pointer;text-decoration:none;white-space:nowrap}
.bbtn-primary{background:#16306B;color:#F4F2EB}.bbtn-primary:hover{background:#2F6BFF;text-decoration:none}
.bbtn-ghost{background:transparent;border-color:#DCE3EF;color:#1E2A45}.bbtn-ghost:hover{border-color:#2F6BFF;color:#2F6BFF;text-decoration:none}
.bbtn-go{background:#15B877;color:#fff}
.bbtn-sm{padding:.4em .85em;font-size:.82rem}
.chip-toggle{display:inline-flex;align-items:center;gap:.5em;background:#fff;border:1px solid #DCE3EF;border-radius:999px;padding:.42em .95em;font-size:.85rem;font-weight:600;color:#586079;cursor:pointer}
.chip-toggle.on{background:rgba(245,179,18,.14);border-color:#FAD56A;color:#B5790F}
.chip-toggle .led{width:8px;height:8px;border-radius:50%;background:#DCE3EF}
.chip-toggle.on .led{background:#F5B312}
.searchbox{display:flex;align-items:center;gap:.5em;background:#fff;border:1px solid #DCE3EF;border-radius:999px;padding:.34em .9em;color:#586079;font-size:.88rem}
.searchbox input{border:none;outline:none;font:inherit;font-size:.88rem;width:150px;background:none}

.filters{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:14px}
.fchip{font-size:.83rem;font-weight:600;padding:.4em .9em;border-radius:999px;border:1px solid #DCE3EF;background:#fff;color:#586079;text-decoration:none}
.fchip:hover{text-decoration:none;border-color:#2F6BFF}
.fchip.on{background:#16306B;border-color:#16306B;color:#fff}
.fchip.attn.on{background:#B5790F;border-color:#B5790F}
.fchip .c{opacity:.7;font-weight:500}

.btbl{background:#fff;border:1px solid #DCE3EF;border-radius:14px;overflow:visible}
.btbl-scroll{overflow-x:auto}
table.bcases{width:100%;border-collapse:collapse;font-size:.9rem;min-width:820px}
table.bcases thead th{text-align:left;font-size:.72rem;letter-spacing:.05em;text-transform:uppercase;color:#586079;font-weight:700;padding:12px 14px;border-bottom:1px solid #DCE3EF;background:#F5F7FB}
table.bcases tbody td{padding:12px 14px;border-bottom:1px solid #DCE3EF;vertical-align:middle}
table.bcases tbody tr:last-child td{border-bottom:none}
table.bcases tbody tr.sel{background:rgba(47,107,255,.05)}
table.bcases tbody tr.settled-row{background:rgba(21,184,119,.06)}
table.bcases tbody tr.attn-row{box-shadow:inset 3px 0 0 #F5B312}
.cp .nm{font-weight:600}
.cp .em{font-size:.8rem;color:#586079}
.amt{font-family:"Spline Sans Mono",monospace;font-weight:500;white-space:nowrap}
.bidcell{font-family:"Spline Sans Mono",monospace;font-size:.82rem;white-space:nowrap}
.bidcell.empty{color:#586079;font-family:inherit;font-style:italic}
.bidcell .tri{color:#586079}
.bcases input[type=checkbox]{width:16px;height:16px;accent-color:#2F6BFF;cursor:pointer}
.bpill{font-size:.73rem;font-weight:600;padding:.28em .72em;border-radius:999px;border:1px solid #DCE3EF;color:#586079;white-space:nowrap;display:inline-block}
.bpill.draft{background:#EAEFF7}
.bpill.awaiting{background:rgba(245,179,18,.14);border-color:#FAD56A;color:#B5790F}
.bpill.progress{background:rgba(47,107,255,.10);border-color:#2F6BFF;color:#2F6BFF}
.bpill.converging{background:rgba(47,107,255,.16);border-color:#2F6BFF;color:#16306B}
.bpill.settled{background:rgba(21,184,119,.16);border-color:#15B877;color:#1c5e3f}
.bpill.declined{background:#fbeae2;border-color:#e6b39a;color:#8a3d1a}
.bpill.closed{background:#EAEFF7;color:#586079}
.tags{display:flex;gap:.35rem;align-items:center;margin-top:.3rem;flex-wrap:wrap}
.minitag{font-size:.68rem;font-weight:700;padding:.12em .5em;border-radius:999px}
.minitag.nudge{background:rgba(245,179,18,.16);color:#B5790F}
.minitag.stall{background:#fbeae2;color:#8a3d1a}
.rowacts{display:flex;gap:.4rem;justify-content:flex-end;align-items:center;flex-wrap:wrap}

.bulkbar{position:sticky;bottom:16px;z-index:15;margin-top:16px;display:none;align-items:center;gap:.7rem;flex-wrap:wrap;background:#16306B;color:#EAF0FF;border-radius:14px;padding:12px 18px;box-shadow:0 10px 30px rgba(22,48,107,.28)}
.bulkbar.show{display:flex}
.bulkbar .cnt{font-weight:700}
.bulkbar .spacer{flex:1}
.bulkbar .bbtn-ghost{border-color:rgba(255,255,255,.35);color:#EAF0FF;background:transparent}
.bulkbar .bbtn-ghost:hover{background:rgba(255,255,255,.1);border-color:#fff;color:#fff}

.modal-bg{position:fixed;inset:0;background:rgba(22,48,107,.42);display:none;align-items:center;justify-content:center;padding:22px;z-index:40}
.modal-bg.show{display:flex}
.modal{background:#fff;border-radius:18px;max-width:560px;width:100%;padding:26px;max-height:88vh;overflow:auto}
.modal h2{font-family:"Fraunces",Georgia,serif;font-weight:500;font-size:1.35rem;margin-bottom:.3rem}
.modal .x{float:right;background:none;border:none;font-size:1.4rem;color:#586079;cursor:pointer;line-height:1}
.modal textarea{width:100%;min-height:130px;border:1px solid #DCE3EF;border-radius:10px;padding:.7em .9em;font-family:"Spline Sans Mono",monospace;font-size:.82rem;resize:vertical;margin-top:.4rem}
.modal input[type=text],.modal input[type=email],.modal input[type=number],.modal select{width:100%;border:1px solid #DCE3EF;border-radius:10px;padding:.6em .8em;font:inherit;font-size:.88rem;margin-top:.3rem}
.modal .frow{margin-top:.8rem}
.modal .frow label{font-size:.8rem;font-weight:700;color:#586079}
.modal .crow{display:flex;align-items:center;gap:.5em;margin-top:1rem;font-size:.88rem}
.modal .foot{display:flex;justify-content:flex-end;gap:.6rem;margin-top:1.2rem}
.confirm-list{background:#F5F7FB;border:1px solid #DCE3EF;border-radius:10px;padding:.6em .9em;margin-top:.7rem;font-size:.86rem;max-height:180px;overflow:auto}
.flash{background:rgba(21,184,119,.12);border:1px solid #7FE0AC;color:#1c5e3f;padding:.8em 1.1em;border-radius:12px;font-size:.9rem;margin-bottom:16px}
.empty-note{color:#586079;font-size:.9rem;margin-top:12px}

@media (max-width:820px){.kpis{grid-template-columns:repeat(2,1fr);margin-top:-30px}.anchors{grid-template-columns:1fr}}
</style>

<% if (flash) { %><div class="flash"><%= flash %></div><% } %>

<!-- ============ KPI TILES ============ -->
<div class="kpis">
  <div class="kpi">
    <div class="kpi-label">Total in dispute</div>
    <div class="kpi-num"><%= money(kpis.totalInDispute, cur) %></div>
    <% const dD = delta(sInDispute); %>
    <div class="kpi-delta <%= dD > 0 ? 'up' : (dD < 0 ? 'down' : 'flat') %>">
      <%= dD === 0 ? '—' : (dD > 0 ? '▲ ' : '▼ ') + money(Math.abs(dD), cur) %>
      <span class="sub">vs 4 weeks ago</span>
    </div>
    <svg class="kpi-spark" viewBox="0 0 100 28" preserveAspectRatio="none"><polyline points="<%= sparkPts(sInDispute) %>" fill="none" stroke="#2F6BFF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>

  <div class="kpi">
    <div class="kpi-label">Respondent join rate</div>
    <div class="kpi-num"><%= kpis.joinRate %>%</div>
    <% const dJ = delta(sJoin); %>
    <div class="kpi-delta <%= dJ > 0 ? 'up' : (dJ < 0 ? 'down' : 'flat') %>">
      <%= dJ === 0 ? '—' : (dJ > 0 ? '▲ ' : '▼ ') + Math.abs(dJ) + ' pts' %>
      <span class="sub">vs 4 weeks ago</span>
    </div>
    <svg class="kpi-spark" viewBox="0 0 100 28" preserveAspectRatio="none"><polyline points="<%= sparkPts(sJoin) %>" fill="none" stroke="#2F6BFF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>

  <a class="kpi <%= filter === 'converging' ? 'on' : '' %>" href="/business?filter=<%= filter === 'converging' ? 'all' : 'converging' %>">
    <div class="kpi-label">In settlement band</div>
    <div class="kpi-num"><%= kpis.inBand %></div>
    <div class="kpi-delta flat">Ready to approve <span class="sub">glance &amp; sign</span></div>
    <svg class="kpi-spark" viewBox="0 0 100 28" preserveAspectRatio="none"><polyline points="<%= sparkPts(sBand) %>" fill="none" stroke="#16306B" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>

  <div class="kpi">
    <div class="kpi-label">Settled value</div>
    <div class="kpi-num"><%= money(kpis.settledValue, cur) %></div>
    <% const dS = delta(sSettled); %>
    <div class="kpi-delta <%= dS > 0 ? 'up' : 'flat' %>">
      <%= dS === 0 ? '—' : '▲ ' + money(dS, cur) %>
      <span class="sub">last 4 weeks</span>
    </div>
    <svg class="kpi-spark" viewBox="0 0 100 28" preserveAspectRatio="none"><polyline points="<%= sparkPts(sSettled) %>" fill="none" stroke="#15B877" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</div>

<!-- ============ STAGE PATH ============ -->
<div class="bcard">
  <div class="ov-head">
    <div><div class="ov-title">Pipeline</div><div class="b-muted">Click a stage to filter the list below.</div></div>
  </div>
  <div class="path">
    <% stages.forEach(function (s) { const m = STAGE_META[s]; %>
      <a class="pathstep <%= filter === s ? 'on' : '' %>" href="/business?filter=<%= filter === s ? 'all' : s %>">
        <div class="ps-name"><span class="ps-dot" style="background:<%= m.color %>"></span><%= m.label %></div>
        <div class="ps-count"><%= counts[s] %></div>
      </a>
    <% }); %>
  </div>
  <% if (counts.declined) { %>
    <div class="path-extra">
      <a class="declined-chip <%= filter === 'declined' ? 'on' : '' %>" href="/business?filter=<%= filter === 'declined' ? 'all' : 'declined' %>">Declined · <%= counts.declined %></a>
      <span class="b-muted">off-pipeline — needs a fresh invite or closing</span>
    </div>
  <% } %>
</div>

<!-- ============ BID BAR ============ -->
<div class="bcard">
  <div class="bidbar-head">
    <div class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 20V10M12 20V4M20 20v-7"/></svg></div>
    <div>
      <div class="ov-title">Your bid bar</div>
      <div class="b-muted">Three figures, set once as a share of each dispute's value — saved as presets, applied across cases.</div>
    </div>
  </div>

  <form method="POST" action="/business/bidbar" id="barForm">
    <div class="preset-row">
      <label for="presetSel">Preset</label>
      <select id="presetSel" onchange="loadPreset()">
        <option value="-1">Custom…</option>
        <% presets.forEach(function (p) { %>
          <option value="<%= p.ideal_pct %>|<%= p.target_pct %>|<%= p.walk_pct %>"><%= p.name %> (<%= p.ideal_pct %>/<%= p.target_pct %>/<%= p.walk_pct %>)</option>
        <% }); %>
      </select>
      <span style="margin-left:auto"></span>
      <input type="text" id="presetName" placeholder="Name this preset…" style="width:170px" />
      <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="savePreset()">Save current</button>
    </div>

    <div class="anchors">
      <div class="anchor ideal">
        <div class="tag"><span class="dot"></span>Ideal</div>
        <div class="pctline"><span class="pct" id="pIdeal"><%= bar.i %></span><span class="pctlab">% of each amount</span></div>
        <input type="range" min="50" max="100" value="<%= bar.i %>" id="rIdeal" name="ideal" oninput="onAnchor()" aria-label="Ideal percentage" />
        <div class="hint" id="hIdeal">The best realistic recovery you'd hope for.</div>
      </div>
      <div class="anchor target">
        <div class="tag"><span class="dot"></span>Target</div>
        <div class="pctline"><span class="pct" id="pTarget"><%= bar.t %></span><span class="pctlab">% of each amount</span></div>
        <input type="range" min="30" max="100" value="<%= bar.t %>" id="rTarget" name="target" oninput="onAnchor()" aria-label="Target percentage" />
        <div class="hint" id="hTarget">The figure you'd genuinely be happy to accept.</div>
      </div>
      <div class="anchor walk">
        <div class="tag"><span class="dot"></span>Walk-away</div>
        <div class="pctline"><span class="pct" id="pWalk"><%= bar.w %></span><span class="pctlab">% of each amount</span></div>
        <input type="range" min="10" max="100" value="<%= bar.w %>" id="rWalk" name="walk" oninput="onAnchor()" aria-label="Walk-away percentage" />
        <div class="hint" id="hWalk">The least you'll accept before escalating.</div>
      </div>
    </div>

    <div class="bidbar-foot">
      <div class="apply-to">
        Apply to
        <select name="scope" id="barScope">
          <option value="selected">selected cases</option>
          <option value="open" selected>all open cases</option>
          <option value="nobar">cases with no bar yet</option>
        </select>
      </div>
      <div class="note">Each case keeps its own figures, worked out from its own amount. Nothing is shared with the other side — they only ever see how close you are.</div>
      <button type="submit" class="bbtn bbtn-primary">Apply bid bar</button>
    </div>
  </form>
</div>

<!-- hidden form used by "Save current" -->
<form method="POST" action="/business/presets" id="presetForm" style="display:none">
  <input type="hidden" name="name" id="pfName" />
  <input type="hidden" name="ideal" id="pfI" />
  <input type="hidden" name="target" id="pfT" />
  <input type="hidden" name="walk" id="pfW" />
</form>

<!-- ============ TOOLBAR ============ -->
<div class="btoolbar">
  <button type="button" class="bbtn bbtn-primary bbtn-sm" onclick="openModal('newModal')">+ New dispute</button>
  <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="openModal('importModal')">⬆ Import from spreadsheet</button>
  <form method="POST" action="/business/nudge" style="display:inline">
    <input type="hidden" name="on" value="<%= nudgeOn ? '0' : '1' %>" />
    <button type="submit" class="chip-toggle <%= nudgeOn ? 'on' : '' %>">
      <span class="led"></span>Auto-nudge: <%= nudgeOn ? 'on · day 3 · 7 · 14' : 'off' %>
    </button>
  </form>
  <a class="bbtn bbtn-ghost bbtn-sm" href="/business/export.csv">⬇ Export CSV</a>
  <div class="spacer"></div>
  <form method="GET" action="/business" class="searchbox">
    <input type="hidden" name="filter" value="<%= filter %>" />
    🔍 <input type="text" name="q" value="<%= q %>" placeholder="Search disputes…" />
  </form>
</div>

<!-- ============ FILTERS ============ -->
<%
  const fdefs = [['all','All open',counts.all],['attn','Needs attention',counts.attn],['awaiting','Awaiting',counts.awaiting],
                 ['converging','Converging',counts.converging],['nobar','No bid bar',counts.nobar],['settled','Settled',counts.settled]];
%>
<div class="filters">
  <% fdefs.forEach(function (f) { %>
    <a class="fchip <%= f[0] === 'attn' ? 'attn' : '' %> <%= filter === f[0] ? 'on' : '' %>" href="/business?filter=<%= f[0] %><%= q ? '&q=' + encodeURIComponent(q) : '' %>"><%= f[1] %> <span class="c"><%= f[2] %></span></a>
  <% }); %>
</div>

<!-- ============ TABLE ============ -->
<%
  const ql = (q || '').toLowerCase();
  const visible = cases.filter(function (c) {
    if (ql && !((c.title + ' ' + c.other_email + ' ' + (c.our_ref || '') + ' ' + c.id).toLowerCase().includes(ql))) return false;
    if (filter === 'all') return !['settled','declined','closed'].includes(c.status);
    if (filter === 'attn') return c.attention;
    if (filter === 'nobar') return !['settled','declined','closed'].includes(c.status) && !c.hasBar;
    if (filter === 'declined') return c.status === 'declined';
    return c.stage === filter;
  });
%>
<form method="POST" action="/business/bulk" id="bulkForm">
  <input type="hidden" name="action" id="bulkAction" />
  <div class="btbl"><div class="btbl-scroll">
    <table class="bcases">
      <thead>
        <tr>
          <th style="width:34px"><input type="checkbox" id="selAll" onchange="toggleAll(this.checked)" aria-label="Select all" /></th>
          <th>Counterparty</th><th>Amount</th><th>Bid bar (I / T / W)</th><th>Status</th>
          <th style="text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody>
      <% visible.forEach(function (c) { %>
        <tr class="<%= c.status === 'settled' ? 'settled-row' : '' %> <%= c.attention ? 'attn-row' : '' %>">
          <td>
            <% if (!['settled','declined','closed'].includes(c.status)) { %>
              <input type="checkbox" name="ids" value="<%= c.id %>" onchange="onSelect()" aria-label="Select <%= c.title %>" />
            <% } %>
          </td>
          <td>
            <div class="cp">
              <div class="nm"><%= c.title %></div>
              <div class="em"><%= c.other_email %> · MB-<%= c.id %><%= c.our_ref ? ' · ' + c.our_ref : '' %></div>
            </div>
          </td>
          <td class="amt"><%= money(c.amount, c.currency) %></td>
          <td>
            <% if (c.hasBar) { %>
              <span class="bidcell"><%= money(c.claim_ideal, c.currency) %> <span class="tri">/</span> <%= money(c.claim_fair, c.currency) %> <span class="tri">/</span> <%= money(c.claim_value, c.currency) %></span>
            <% } else { %>
              <span class="bidcell empty">not set</span>
            <% } %>
          </td>
          <td>
            <%
              const pillClass = c.status === 'declined' ? 'declined' : (c.status === 'closed' ? 'closed' : c.stage);
              let pillText = STAGE_META[c.stage] ? STAGE_META[c.stage].label : c.status;
              if (c.stage === 'draft') pillText = 'Draft — not invited';
              if (c.stage === 'awaiting') pillText = 'Awaiting response';
              if (c.status === 'settled') pillText = 'Settled at ' + money(c.settled_value, c.currency);
              if (c.status === 'declined') pillText = 'Declined';
              if (c.status === 'closed') pillText = 'Closed';
            %>
            <span class="bpill <%= pillClass %>"><%= pillText %></span>
            <% if (c.stage === 'awaiting' && nudgeOn) { %><div class="tags"><span class="minitag nudge">auto-nudge</span><% if (c.stalled) { %><span class="minitag stall">stalled <%= c.age %>d</span><% } %></div><% } %>
          </td>
          <td>
            <div class="rowacts">
              <% if (c.stage === 'draft') { %>
                <button type="button" class="bbtn bbtn-primary bbtn-sm" onclick="oneAction(<%= c.id %>,'invite')">Invite</button>
              <% } else if (c.stage === 'awaiting') { %>
                <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="oneAction(<%= c.id %>,'remind')">Remind</button>
              <% } else if (c.stage === 'converging') { %>
                <a class="bbtn bbtn-go bbtn-sm" href="/cases/<%= c.id %>">Approve</a>
              <% } %>
              <a class="bbtn bbtn-ghost bbtn-sm" href="/cases/<%= c.id %>">Open</a>
            </div>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div></div>
  <% if (!visible.length) { %><p class="empty-note">No disputes match this view.</p><% } %>

  <!-- ============ BULK BAR ============ -->
  <div class="bulkbar" id="bulkbar">
    <span class="cnt"><span id="bulkCount">0</span> selected</span>
    <div class="spacer"></div>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="doBulk('invite')">Invite</button>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="barFromSelection()">Set bid bar</button>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="doBulk('remind')">Remind</button>
    <button type="button" class="bbtn bbtn-go bbtn-sm" onclick="openApprove()">Approve &amp; settle</button>
    <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="if(confirm('Close the selected disputes? This cannot be undone from here.')) doBulk('close')">Close</button>
  </div>
</form>

<!-- ============ NEW DISPUTE MODAL ============ -->
<div class="modal-bg" id="newModal">
  <div class="modal">
    <button class="x" type="button" onclick="closeModal('newModal')" aria-label="Close">×</button>
    <h2>New dispute</h2>
    <p class="b-muted">Added as a draft. Nothing is sent until you invite.</p>
    <form method="POST" action="/business/new">
      <div class="frow"><label>Counterparty name</label><input type="text" name="title" required /></div>
      <div class="frow"><label>Their email</label><input type="email" name="other_email" required /></div>
      <div class="frow"><label>Amount in dispute</label><input type="number" name="amount" min="1" required /></div>
      <div class="frow"><label>Currency</label>
        <select name="currency">
          <% Object.keys(CURRENCIES).forEach(function (k) { %><option value="<%= k %>"><%= CURRENCIES[k].label %></option><% }); %>
        </select>
      </div>
      <div class="frow"><label>Your reference (optional)</label><input type="text" name="our_ref" /></div>
      <label class="crow"><input type="checkbox" name="apply_bar" value="1" checked /> Apply the current bid bar</label>
      <div class="foot">
        <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="closeModal('newModal')">Cancel</button>
        <button type="submit" class="bbtn bbtn-primary bbtn-sm">Add dispute</button>
      </div>
    </form>
  </div>
</div>

<!-- ============ IMPORT MODAL ============ -->
<div class="modal-bg" id="importModal">
  <div class="modal">
    <button class="x" type="button" onclick="closeModal('importModal')" aria-label="Close">×</button>
    <h2>Import disputes</h2>
    <p class="b-muted">Paste rows as <b>counterparty, email, amount, currency, your-ref</b>. One dispute per line. A header row is ignored.</p>
    <form method="POST" action="/business/import">
      <textarea name="csv" placeholder="Northgate Supplies, ap@northgate.co.uk, 4500, GBP, INV-2231&#10;Bluewater Facilities, accounts@bluewater.io, 2750, GBP, INV-2244"></textarea>
      <label class="crow"><input type="checkbox" name="apply_bar" value="1" checked /> Apply the current bid bar to every imported dispute</label>
      <div class="foot">
        <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="closeModal('importModal')">Cancel</button>
        <button type="submit" class="bbtn bbtn-primary bbtn-sm">Create disputes</button>
      </div>
    </form>
  </div>
</div>

<!-- ============ APPROVE MODAL ============ -->
<div class="modal-bg" id="approveModal">
  <div class="modal">
    <button class="x" type="button" onclick="closeModal('approveModal')" aria-label="Close">×</button>
    <h2>Approve &amp; settle</h2>
    <p class="b-muted">Approving is binding. Only the selected cases already in the settle band are approved — the rest are skipped. Please glance over them first.</p>
    <div class="confirm-list" id="approveList"></div>
    <div class="foot">
      <button type="button" class="bbtn bbtn-ghost bbtn-sm" onclick="closeModal('approveModal')">Cancel</button>
      <button type="button" class="bbtn bbtn-go bbtn-sm" id="approveGo" onclick="doBulk('approve')">Approve these</button>
    </div>
  </div>
</div>

<script>
// Which selected cases are actually in the settle band — used by the confirm step.
var BAND = <%- JSON.stringify(cases.filter(function (c) { return c.stage === 'converging'; }).map(function (c) { return { id: c.id, t: c.title }; })) %>;

var HINTS = {
  ideal: ['A firm opening — little room to move.', "The best realistic recovery you'd hope for.", 'Ambitious. Signals confidence in the claim.'],
  target: ["The figure you'd genuinely accept.", 'A fair middle most cases settle around.', 'Reasonable — likely to land a deal.'],
  walk: ["The least you'll accept before escalating.", 'A cautious floor — protects you late on.', 'Low floor: quicker deals, smaller recovery.']
};
function pickHint(k, v) { var a = HINTS[k]; return v >= 85 ? a[2] : (v >= 60 ? a[1] : a[0]); }

function onAnchor() {
  var i = +rIdeal.value, t = +rTarget.value, w = +rWalk.value;
  if (t > i) { t = i; rTarget.value = i; }
  if (w > t) { w = t; rWalk.value = t; }
  pIdeal.textContent = i; pTarget.textContent = t; pWalk.textContent = w;
  hIdeal.textContent = pickHint('ideal', i);
  hTarget.textContent = pickHint('target', t);
  hWalk.textContent = pickHint('walk', w);
}
function loadPreset() {
  var v = document.getElementById('presetSel').value;
  if (v === '-1') return;
  var p = v.split('|');
  rIdeal.value = p[0]; rTarget.value = p[1]; rWalk.value = p[2];
  onAnchor();
}
function savePreset() {
  var nm = (document.getElementById('presetName').value || '').trim();
  if (!nm) { alert('Give the preset a name first.'); return; }
  document.getElementById('pfName').value = nm;
  document.getElementById('pfI').value = rIdeal.value;
  document.getElementById('pfT').value = rTarget.value;
  document.getElementById('pfW').value = rWalk.value;
  document.getElementById('presetForm').submit();
}

function checks() { return [].slice.call(document.querySelectorAll('#bulkForm input[name=ids]')); }
function selected() { return checks().filter(function (c) { return c.checked; }); }
function onSelect() {
  checks().forEach(function (cb) { cb.closest('tr').classList.toggle('sel', cb.checked); });
  var n = selected().length;
  document.getElementById('bulkCount').textContent = n;
  document.getElementById('bulkbar').classList.toggle('show', n > 0);
}
function toggleAll(on) { checks().forEach(function (cb) { cb.checked = on; }); onSelect(); }

function doBulk(action) {
  if (!selected().length) { alert('Nothing selected.'); return; }
  document.getElementById('bulkAction').value = action;
  document.getElementById('bulkForm').submit();
}
// Row-level action: tick just that row, then reuse the bulk endpoint.
function oneAction(id, action) {
  checks().forEach(function (cb) { cb.checked = (+cb.value === id); });
  doBulk(action);
}
// "Set bid bar" from the selection: copy the ticked ids into the bid bar form.
function barFromSelection() {
  var form = document.getElementById('barForm');
  [].slice.call(form.querySelectorAll('input[name=ids]')).forEach(function (n) { n.remove(); });
  selected().forEach(function (cb) {
    var h = document.createElement('input');
    h.type = 'hidden'; h.name = 'ids'; h.value = cb.value;
    form.appendChild(h);
  });
  document.getElementById('barScope').value = 'selected';
  form.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function openModal(id) { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
function openApprove() {
  var picked = selected().map(function (c) { return +c.value; });
  var elig = BAND.filter(function (b) { return picked.indexOf(b.id) > -1; });
  var list = document.getElementById('approveList');
  var go = document.getElementById('approveGo');
  if (!elig.length) {
    list.innerHTML = '<div class="b-muted">None of the selected cases are in the settle band yet. Approving is only offered once the figures converge.</div>';
    go.style.display = 'none';
  } else {
    list.innerHTML = elig.map(function (b) { return '<div><b>' + b.t + '</b> · MB-' + b.id + '</div>'; }).join('');
    go.style.display = '';
  }
  openModal('approveModal');
}

onAnchor(); onSelect();
</script>

<%- include('partials/foot') %>

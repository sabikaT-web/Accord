<%- include('partials/head') %>
<style>main>.wrap{max-width:1160px}.bar-in{max-width:1160px}</style>

<nav class="admin-nav">
  <a href="/admin">Dashboard</a>
  <a href="/admin/users">Users</a>
  <a href="/admin/cases" class="on">Cases</a>
</nav>

<div class="admin-head">
  <h1 class="page serif">Cases <span class="count">(<%= cases.length %>)</span></h1>
  <a class="btn btn-ghost" href="/admin/cases.csv">Export CSV</a>
</div>

<form class="search" method="GET" action="/admin/cases">
  <input type="text" name="q" value="<%= q %>" placeholder="Search by title, email, or MB-id…" />
  <button class="btn btn-primary" type="submit">Search</button>
  <% if (q) { %><a class="muted" href="/admin/cases">clear</a><% } %>
</form>

<div class="table-wrap">
  <table class="grid">
    <thead><tr>
      <th>Case</th><th>Claimant (owed)</th><th>Respondent (owes)</th><th>Amount</th><th>Status</th><th>Progress</th><th>Created</th>
    </tr></thead>
    <tbody>
      <% if (cases.length === 0) { %>
        <tr><td colspan="7" class="muted" style="text-align:center;padding:24px">No cases found.</td></tr>
      <% } %>
      <% cases.forEach(function(c){ var p = progressFor(c); %>
        <tr class="clickable" onclick="location.href='/admin/cases/<%= c.id %>'">
          <td><strong>MB-<%= c.id %></strong><br><span class="muted"><%= c.title %></span></td>
          <td><%= c.claimant_acc_email || (c.respondent_acc_email ? c.other_email : '—') %></td>
          <td><%= c.respondent_acc_email || (c.claimant_acc_email ? c.other_email : '—') %></td>
          <td>£<%= fmt(c.amount) %></td>
          <td><span class="badge <%= c.status==='settled'?'green':(c.status==='closed'?'grey':'blue') %>"><%= statusText(c) %></span></td>
          <td><div class="prog"><div class="prog-fill" style="width:<%= p %>%"></div></div><span class="muted"><%= p %>%</span></td>
          <td><%= fmtDay(c.created_at) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/foot') %>

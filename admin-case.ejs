<%- include('partials/head') %>
<style>
  main>.wrap{max-width:1000px}
  .doc-rows{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.55rem}
  .doc-row{display:flex;align-items:center;gap:.85rem;padding:.65rem .8rem;border:1px solid #e3e6ec;border-radius:10px;background:#fbfcfe}
  .doc-ico{flex:0 0 auto;width:44px;text-align:center;font-size:.6rem;font-weight:700;letter-spacing:.04em;color:#fff;background:#8a8f99;border-radius:6px;padding:.32rem 0}
  .doc-ico.pdf{background:#c0392b}
  .doc-ico.img{background:#2b7a4b}
  .doc-ico.xls{background:#1d6f42}
  .doc-ico.doc{background:#2b54e6}
  .doc-main{flex:1;min-width:0;display:flex;flex-direction:column;gap:.15rem}
  .doc-name{font-weight:600;color:#1e2a45;word-break:break-word}
  .doc-meta{font-size:.78rem}
  .doc-acts{flex:0 0 auto;display:flex;gap:.4rem}
  .btn.sm{padding:.32rem .7rem;font-size:.8rem}
  @media(max-width:640px){.doc-row{flex-wrap:wrap}.doc-acts{width:100%;justify-content:flex-end}}
</style>

<nav class="admin-nav">
  <a href="/admin">Dashboard</a>
  <a href="/admin/users">Users</a>
  <a href="/admin/cases" class="on">Cases</a>
</nav>

<p><a href="/admin/cases" class="muted">← All cases</a></p>
<div class="admin-head">
  <h1 class="page serif">MB-<%= c.id %> · <%= c.title %></h1>
  <span class="badge <%= c.status==='settled'?'green':(c.status==='closed'?'grey':'blue') %>"><%= statusText(c) %></span>
</div>

<div class="prog big"><div class="prog-fill" style="width:<%= progressFor(c) %>%"></div></div>
<p class="muted" style="margin-bottom:1.4rem"><%= progressFor(c) %>% complete</p>

<div class="two-col">
  <div class="card">
    <h2>Claimant <span class="muted">(owed money)</span></h2>
    <p><strong><%= c.claimant_acc_email || '—' %></strong><br>
       <span class="muted"><%= c.claimant_name || (c.claimant_acc_email ? '' : 'not joined — invited: ' + c.other_email) %></span></p>
    <p class="figure">Least they'll accept: <strong><%= c.claim_value != null ? money(c.claim_value, c.currency) : '— not entered' %></strong></p>
  </div>
  <div class="card">
    <h2>Respondent <span class="muted">(owes money)</span></h2>
    <p><strong><%= c.respondent_acc_email || '—' %></strong><br>
       <span class="muted"><%= c.respondent_name || (c.respondent_acc_email ? '' : 'not joined — invited: ' + c.other_email) %></span></p>
    <p class="figure">Most they'll pay: <strong><%= c.resp_value != null ? money(c.resp_value, c.currency) : '— not entered' %></strong></p>
  </div>
</div>

<div class="card">
  <h2>Case details</h2>
  <table class="kv">
    <tr><td>Amount in dispute</td><td><%= money(c.amount, c.currency) %></td></tr>
    <tr><td>Settlement amount</td><td><%= c.settled_value != null ? money(c.settled_value, c.currency) : '—' %></td></tr>
    <tr><td>Created</td><td><%= fmtDate(c.created_at) %></td></tr>
    <tr><td>Settled</td><td><%= fmtDate(c.settled_at) %></td></tr>
    <tr><td>Claimant details</td><td><%= [c.claim_company, c.claim_address].filter(Boolean).join(' — ') || '— not provided' %></td></tr>
    <tr><td>Respondent details</td><td><%= [c.resp_company, c.resp_address].filter(Boolean).join(' — ') || '— not provided' %></td></tr>
  </table>
  <p class="note-figs muted">Figures are shown here for your operational oversight only. The two parties never see each other's number inside the product.</p>
</div>

<div class="card">
  <h2>Documents <span class="muted">(<%= docs.length %>)</span></h2>
  <% if (docs.length === 0) { %>
    <p class="muted">No documents were attached to this case.</p>
  <% } else { %>
    <ul class="doc-rows">
      <% docs.forEach(function(d){ %>
        <li class="doc-row">
          <span class="doc-ico <%= /pdf/.test(d.mime) ? 'pdf' : (/^image\//.test(d.mime) ? 'img' : (/sheet|excel|csv/.test(d.mime) ? 'xls' : (/word|document/.test(d.mime) ? 'doc' : 'file'))) %>"><%= /pdf/.test(d.mime) ? 'PDF' : (/^image\//.test(d.mime) ? 'IMG' : (/sheet|excel|csv/.test(d.mime) ? 'XLS' : (/word|document/.test(d.mime) ? 'DOC' : 'FILE'))) %></span>
          <span class="doc-main">
            <span class="doc-name"><%= d.filename %></span>
            <span class="muted doc-meta"><%= (d.size/1024).toFixed(0) %> KB · uploaded by <%= d.uploader_email || 'unknown' %> · <%= fmtDate(d.created_at) %></span>
          </span>
          <span class="doc-acts">
            <a class="btn btn-ghost sm" href="/admin/cases/<%= c.id %>/documents/<%= d.id %>" target="_blank" rel="noopener">View</a>
            <a class="btn btn-ghost sm" href="/admin/cases/<%= c.id %>/documents/<%= d.id %>?download=1">Download</a>
          </span>
        </li>
      <% }) %>
    </ul>
    <p class="note-figs muted">Documents are supplied by the parties as identifiers for the case. They are assessed solely for the purpose of mediation, and only where a human mediator is involved.</p>
  <% } %>
</div>

<div class="card">
  <h2>Timeline</h2>
  <% if (events.length === 0) { %><p class="muted">No events yet.</p><% } else { %>
    <ul class="timeline">
      <% events.forEach(function(e){ %>
        <li class="tl-<%= e.kind %>">
          <div class="tl-dot"></div>
          <div class="tl-body">
            <div class="tl-kind"><%= e.kind.replace('_',' ') %></div>
            <% if (e.detail) { %><div class="muted"><%= e.detail %></div><% } %>
            <div class="ts"><%= fmtDate(e.created_at) %></div>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</div>

<div class="card">
  <h2>Actions</h2>
  <div class="actions-row">
    <a class="btn btn-ghost" href="/admin/cases/<%= c.id %>/settlement.txt">Download settlement</a>
    <% if (c.status === 'closed') { %>
      <form method="POST" action="/admin/cases/<%= c.id %>/reopen"><button class="btn btn-primary" type="submit">Reopen case</button></form>
    <% } else { %>
      <form method="POST" action="/admin/cases/<%= c.id %>/close" onsubmit="return confirm('Close this case?')"><button class="btn btn-ghost" type="submit">Close case</button></form>
    <% } %>
  </div>
</div>

<%- include('partials/foot') %>

<%- include('partials/head', { pageHead: {
  eyebrow: 'Case MB-' + c.id + ' \u00b7 ' + (role === 'claim' ? 'Claimant' : 'Respondent'),
  title: c.title,
  sub: money(c.amount, c.currency) + ' in dispute \u00b7 you are the party who <strong>' + (role === 'claim' ? 'is owed money' : 'owes money') + '</strong>.'
} }) %>

<style>
  .mb-card{margin-top:1rem}
  .mb-figwrap{margin:1.4rem 0 .4rem}
  .mb-fig{font-size:1.7rem;font-weight:600;transition:color .3s ease}
  .mb-figrole{font-size:.85rem;color:#5a5f6b;margin-bottom:1.1rem;min-height:1.1em}

  /* three-anchor legend chips */
  .mb-chips{display:flex;gap:.5rem;flex-wrap:wrap;margin:.2rem 0 1.4rem}
  .mb-chip{display:inline-flex;flex-direction:column;gap:.1rem;padding:.4rem .7rem;border-radius:12px;border:1px solid #dfe3ea;background:#f7f9ff;cursor:pointer;transition:border-color .25s,box-shadow .25s,background .25s}
  .mb-chip .k{font-size:.6rem;letter-spacing:.06em;text-transform:uppercase;font-weight:700;color:#8a8f99}
  .mb-chip .v{font-size:.98rem;font-weight:600;color:#1e2a4a}
  .mb-chip.sel{border-color:#2b54e6;box-shadow:0 0 0 3px rgba(43,84,230,.14);background:#eef3ff}
  .mb-chip[data-slot="ideal"] .k{color:#5b7bf0}
  .mb-chip[data-slot="res"] .k{color:#13205c}

  .mb-track{position:relative;height:8px;border-radius:6px;background:#eef0f4;border:0.5px solid #dfe3ea;margin:2.4rem 0 1.8rem}
  /* your own range: translucent band from lowest to highest figure */
  .mb-band{position:absolute;top:50%;height:8px;transform:translateY(-50%);border-radius:6px;background:linear-gradient(90deg,rgba(91,123,240,.30),rgba(43,84,230,.42),rgba(19,32,92,.34));pointer-events:none;z-index:0;transition:background .4s}

  /* reservation handle = the spinning orbit hub (the binding "walk-away" figure) */
  .mb-you{position:absolute;top:50%;left:50%;width:52px;height:52px;transform:translate(-50%,-50%);cursor:grab;touch-action:none;outline:none;z-index:4}
  .mb-you:active{cursor:grabbing}
  .hub{position:absolute;top:50%;left:50%;width:13px;height:13px;border-radius:50%;background:#fff;border:2px solid #13205c;transform:translate(-50%,-50%);z-index:2;box-shadow:0 0 8px 1px rgba(19,32,92,.4)}
  .ring{position:absolute;inset:0;animation:mb-spin 3.4s linear infinite}
  @keyframes mb-spin{to{transform:rotate(360deg)}}
  .od-blue{position:absolute;top:50%;left:50%;width:14px;height:14px;border-radius:50%;background:#2b54e6;transform:translate(-50%,-50%) translateX(-18px);box-shadow:0 0 11px 3px rgba(43,84,230,.5)}
  .mb-you:focus-visible .hub{box-shadow:0 0 0 4px rgba(43,84,230,.3)}

  /* the two softer handles: ideal (hollow ring) + fair (solid dot) */
  .mb-h{position:absolute;top:50%;left:50%;width:34px;height:34px;transform:translate(-50%,-50%);cursor:grab;touch-action:none;outline:none;z-index:3;display:flex;align-items:center;justify-content:center}
  .mb-h:active{cursor:grabbing}
  .mb-h .dot{width:15px;height:15px;border-radius:50%;transition:transform .15s}
  .mb-h[data-slot="fair"] .dot{background:#2b54e6;box-shadow:0 0 8px 2px rgba(43,84,230,.4)}
  .mb-h[data-slot="ideal"] .dot{background:#fff;border:2px solid #5b7bf0;box-shadow:0 0 7px 1px rgba(91,123,240,.4)}
  .mb-h:focus-visible .dot,.mb-h.live .dot{transform:scale(1.22)}

  .mb-snake{position:absolute;inset:0;pointer-events:none;overflow:visible;z-index:1;transition:opacity .5s ease}
  .seg{position:absolute;border-radius:50%;transform:translate(-50%,-50%)}
  .mb-pops{position:absolute;inset:0;pointer-events:none;overflow:visible;z-index:2}
  .pp{position:absolute;width:9px;height:9px;border-radius:50%;will-change:transform,opacity}
  .mb-scale{display:flex;justify-content:space-between;font-size:.72rem;color:#8a8f99;margin-top:.5rem}

  /* proximity highlight meter — the "you're nearly there" signal */
  .mb-prox{margin:1.1rem 0 .2rem}
  .mb-prox-bar{position:relative;height:7px;border-radius:6px;background:#eef0f4;border:0.5px solid #dfe3ea;overflow:hidden}
  .mb-prox-fill{position:absolute;left:0;top:0;bottom:0;width:0%;border-radius:6px;background:#c7cdda;transition:width .6s cubic-bezier(.2,.7,.3,1),background .5s}
  .mb-prox-fill.lvl-apart{background:#2b54e6}
  .mb-prox-fill.lvl-near{background:#f5b400;box-shadow:0 0 12px 2px rgba(245,180,0,.55)}
  .mb-prox-fill.lvl-close{background:#23a259}
  .mb-prox-fill.lvl-overlap{background:#23a259;box-shadow:0 0 14px 3px rgba(35,162,89,.5)}
  .mb-prox-text{font-size:.78rem;color:#8a8f99;margin-top:.45rem;min-height:1em;transition:color .3s}
  .mb-prox-text.hot{color:#9a6b00;font-weight:600}

  .coach{display:flex;gap:.55rem;align-items:flex-start;margin:1rem 0 0;padding:.7rem .9rem;border-radius:14px;background:#f3f6ff;border:1px solid #e0e7fb;color:#1e2a4a;font-size:.95rem;line-height:1.45}
  .coach .coach-badge{flex:0 0 auto;font-size:.6rem;letter-spacing:.07em;text-transform:uppercase;font-weight:700;color:#fff;background:linear-gradient(135deg,#2647d6,#13205c);padding:.3rem .46rem;border-radius:7px;margin-top:.05rem}
  .coach.tone-warning{background:#fff6ec;border-color:#f2dcc1;color:#5a3a17}
  .coach.tone-close,.coach.tone-success{background:#eef9f1;border-color:#cce9d4;color:#1d4a2c}
  .coach.pop{animation:mb-bpop .34s ease}
  @keyframes mb-bpop{0%{transform:translateY(7px) scale(.98);opacity:.45}100%{transform:translateY(0) scale(1);opacity:1}}
  .mb-actions{display:flex;align-items:center;gap:.8rem;flex-wrap:wrap;margin-top:1.2rem}
  .mb-approve{position:relative;border:none;border-radius:999px;padding:.55rem .7rem;cursor:pointer;opacity:.72;background:linear-gradient(90deg,#2b54e6 0 50%,#f5b400 50% 100%);transition:opacity .4s ease,background .5s ease,box-shadow .5s ease}
  .mb-approve .lbl{position:relative;display:inline-flex;align-items:center;gap:5px;font-size:.9rem;font-weight:600;color:#fff;background:rgba(0,0,0,.32);padding:.3rem .85rem;border-radius:999px;transition:background .5s ease}
  .mb-approve.ready{opacity:1;animation:mb-pulse 1.7s ease-in-out infinite}
  @keyframes mb-pulse{0%,100%{box-shadow:0 0 0 0 rgba(245,180,0,0)}50%{box-shadow:0 0 16px 4px rgba(245,180,0,.45)}}
  .mb-approve.is-green{opacity:1;animation:none;background:#23a259;box-shadow:0 0 22px 6px rgba(35,162,89,.5)}
  .mb-approve.is-green .lbl{background:transparent}
  .mb-med-wrap{margin-top:1.4rem;padding-top:1.1rem;border-top:0.5px solid #e3e6ec;opacity:0;transform:translateY(8px);transition:opacity .5s ease,transform .5s ease;pointer-events:none}
  .mb-med-wrap.show{opacity:1;transform:none;pointer-events:auto}
  .mb-med{display:inline-flex;align-items:center;gap:8px;font-size:.9rem;font-weight:600;color:#13205c;background:transparent;border:0.5px solid #c7cdda;border-radius:999px;padding:.55rem 1.05rem;cursor:pointer;text-decoration:none}
  .mb-med:hover{background:#f3f6ff}
  .mb-med-cap{display:block;font-size:.78rem;color:#8a8f99;margin-top:.5rem}
  .mb-escalate{margin-top:1.2rem;padding-top:1rem;border-top:0.5px dashed #e3e6ec}
  .mb-esc-row{display:flex;align-items:center;gap:.8rem;flex-wrap:wrap}
  .mb-esc-btn{flex:none;display:inline-flex;align-items:center;gap:6px;font-size:.88rem;font-weight:600;color:#13205c;background:#fff;border:1px solid #c7cdda;border-radius:999px;padding:.5rem 1rem;cursor:pointer;transition:background .2s,border-color .2s}
  .mb-esc-btn:hover:not(:disabled){background:#f3f6ff;border-color:#2b54e6}
  .mb-esc-btn:disabled{cursor:default;color:#23a259;border-color:#cce9d4;background:#eef9f1}
  .mb-esc-cap{font-size:.8rem;color:#8a8f99;line-height:1.4;flex:1 1 220px}
  .mb-pay{display:inline-flex;align-items:center;gap:6px;font-size:.92rem;font-weight:700;color:#fff;background:#23a259;border:none;border-radius:999px;padding:.6rem 1.15rem;cursor:pointer;box-shadow:0 0 16px 3px rgba(35,162,89,.35);transition:filter .2s}
  .mb-pay:hover{filter:brightness(1.05)}
  .mb-modal{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;padding:1rem}
  .mb-modal[hidden]{display:none}
  .mb-modal-back{position:absolute;inset:0;background:rgba(16,24,48,.55);backdrop-filter:blur(2px)}
  .mb-modal-card{position:relative;background:#fff;border-radius:18px;box-shadow:0 24px 60px rgba(16,24,48,.28);max-width:460px;width:100%;padding:1.6rem 1.5rem 1.4rem;max-height:88vh;overflow:auto;animation:mbIn .28s cubic-bezier(.2,.9,.3,1)}
  @keyframes mbIn{from{transform:translateY(14px) scale(.98);opacity:0}to{transform:none;opacity:1}}
  .mb-modal-x{position:absolute;top:.7rem;right:.85rem;border:none;background:transparent;font-size:1.5rem;line-height:1;color:#8a8f99;cursor:pointer}
  .mb-modal-badge{display:inline-block;font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:#fff;background:#23a259;padding:.32rem .6rem;border-radius:7px;margin-bottom:.85rem;box-shadow:0 0 16px 3px rgba(35,162,89,.35)}
  .mb-modal-badge.ok{background:#16306B;box-shadow:none}
  .mb-modal-card h2{font-family:"Fraunces",Georgia,serif;font-weight:500;font-size:1.35rem;margin:0 0 .55rem;color:#16306B}
  .mb-modal-sub{font-size:.92rem;line-height:1.5;color:#3b4252;margin:0 0 .9rem}
  .mb-modal-card label{display:block;font-size:.82rem;font-weight:600;color:#3b4252;margin:.85rem 0 .3rem}
  .mb-modal-card .opt{font-weight:400;color:#8a8f99}
  .mb-modal-card input,.mb-modal-card textarea{width:100%;font:inherit;font-size:.92rem;padding:.6rem .7rem;border:1px solid #d6dbe4;border-radius:10px;background:#fbfcfe;resize:vertical}
  .mb-modal-card input:focus,.mb-modal-card textarea:focus{outline:none;border-color:#2b54e6;box-shadow:0 0 0 3px rgba(43,84,230,.15)}
  .mb-modal-err{margin-top:.7rem;font-size:.85rem;color:#7a4a18;background:#fff6ec;border:1px solid #f2dcc1;border-radius:9px;padding:.5rem .7rem}
  .mb-modal-go{display:block;width:100%;margin-top:1.1rem;text-align:center;font:inherit;font-size:.92rem;font-weight:600;color:#fff;background:#23a259;border:none;border-radius:999px;padding:.7rem 1rem;cursor:pointer;text-decoration:none;box-shadow:0 0 18px 3px rgba(35,162,89,.32)}
  .mb-modal-go:disabled{opacity:.6;cursor:default;box-shadow:none}
  .mb-modal-go[aria-disabled="true"]{opacity:.45;cursor:not-allowed;box-shadow:none;pointer-events:none}
  .mb-modal-alt{display:block;text-align:center;margin-top:.8rem;font-size:.85rem;color:#16306B}
  .mb-modal-fine{font-size:.76rem;color:#8a8f99;text-align:center;margin:.75rem 0 0;line-height:1.45}
</style>

<% if (c.status === 'awaiting_other') { %>
  <div class="banner">Waiting for the other party to join. Send them this private link:
    <div class="invite-box" id="inviteBox"><%= inviteUrl %></div>
    <button class="btn btn-ghost" type="button" id="copyBtn" style="margin-top:.7rem">Copy link</button>
  </div>
<% } %>

<div class="card mb-card <%= role === 'claim' ? 'tint-claim' : 'tint-resp' %>">
  <div class="mb-figwrap">
    <div class="mb-fig"><%= cur.symbol %><span id="figNum">0</span></div>
    <div class="mb-figrole" id="figRole">Drag the three handles to set your figures</div>
  </div>

  <div class="mb-chips" id="chips">
    <div class="mb-chip" data-slot="ideal"><span class="k" id="kIdeal">Ideal</span><span class="v"><%= cur.symbol %><span id="vIdeal">0</span></span></div>
    <div class="mb-chip" data-slot="fair"><span class="k">Target</span><span class="v"><%= cur.symbol %><span id="vFair">0</span></span></div>
    <div class="mb-chip" data-slot="res"><span class="k" id="kRes">Walk-away</span><span class="v"><%= cur.symbol %><span id="vRes">0</span></span></div>
  </div>

  <div class="mb-track" id="track">
    <div class="mb-band" id="band"></div>
    <div class="mb-h" id="hIdeal" data-slot="ideal"><span class="dot"></span></div>
    <div class="mb-h" id="hFair" data-slot="fair"><span class="dot"></span></div>
    <div class="mb-you" id="you"><span class="hub"></span><span class="ring" id="ring"><span class="od-blue"></span></span></div>
    <div class="mb-pops" id="pops"></div>
  </div>
  <div class="mb-scale"><span><%= cur.symbol %>0</span><span><%= cur.symbol %><%= fmt(Math.round(c.amount/2)) %></span><span><%= cur.symbol %><%= fmt(c.amount) %></span></div>

  <div class="mb-prox">
    <div class="mb-prox-bar"><div class="mb-prox-fill" id="proxFill"></div></div>
    <div class="mb-prox-text" id="proxText"></div>
  </div>

  <div class="coach tone-<%= status.coach ? status.coach.tone : 'idle' %>" id="coachBox" <%= status.coach ? '' : 'style="display:none"' %>>
    <span class="coach-badge">midbid</span>
    <span class="coach-text" id="coachText"><%= status.coach ? status.coach.text : '' %></span>
  </div>

  <div class="mb-actions">
    <button class="btn btn-primary" type="button" id="saveBtn">Save my figures</button>
    <button class="mb-approve" type="button" id="approve"><span class="lbl" id="approveLbl">Settle</span></button>
    <span class="muted" id="saveHint"></span>
  </div>

  <p class="note">🔒&nbsp; These three figures are yours alone. The other side never sees your numbers — the coach only signals when your ranges get close.</p>

  <div class="mb-escalate" id="escalate">
    <div class="mb-esc-row">
      <button class="mb-esc-btn" type="button" id="mediatorBtn"<%= pay && pay.mediatorRequested ? ' disabled' : '' %>><span id="mediatorLbl"><%= pay && pay.mediatorRequested ? '✓ Human mediator requested' : 'Request a human mediator' %></span></button>
      <span class="mb-esc-cap">Stuck? Bring in an accredited mediator to help close the gap.<%= pay && pay.mediatorNote ? ' ' + pay.mediatorNote : '' %></span>
    </div>
  </div>

  <div class="mb-med-wrap" id="medWrap">
    <% if (c.status === 'settled') { %>
      <span class="mb-med-cap"><% if (pay && pay.enabled && pay.fee && !pay.released) { %>Add your details, then settle the service charge to release your agreement.<% } else { %>Add your details to complete your settlement agreement.<% } %></span>
    <% } %>
    <button id="settleBtn" type="button" hidden aria-hidden="true"></button>
  </div>
</div>

<% if (pay && pay.enabled && pay.fee && c.status === 'settled' && !pay.released) { %>
<div class="card">
  <div class="eyebrow">Service charge</div>
  <h2 style="margin-top:.35rem">Release your settlement agreement</h2>

  <div class="ledger">
    <div class="lrow"><span class="lk">MidBid service charge</span><span class="lv"><%= pay.fee.grossLabel %></span></div>
    <% if (pay.fee.credit > 0) { %>
      <div class="lrow credit"><span class="lk">Less activation fee already paid</span><span class="lv">&minus;<%= pay.fee.creditLabel %></span></div>
    <% } %>
    <% if (pay.myPaid > 0) { %>
      <div class="lrow credit"><span class="lk">You have paid</span><span class="lv">&minus;<%= pay.myPaidLabel %></span></div>
    <% } %>
    <div class="lrow total"><span class="lk">Outstanding on this case</span><span class="lv"><%= pay.fee.outstandingLabel %></span></div>
  </div>

  <form method="POST" action="/cases/<%= c.id %>/pay/success-fee" id="feeForm">
    <p class="muted" style="margin-bottom:.7rem">How would you like to cover it?</p>

    <label class="choice on" id="choiceSplit">
      <input type="radio" name="choice" value="split" checked />
      <span><b>Split it 50/50</b>
      <span>You pay <%= pay.fee.halfLabel %>. The other party is asked to pay their half.</span></span>
    </label>

    <label class="choice" id="choiceFull">
      <input type="radio" name="choice" value="full" />
      <span><b>I&rsquo;ll cover it in full</b>
      <span>You pay <%= pay.fee.outstandingLabel %>. Your agreement is released straight away.</span></span>
    </label>

    <div class="hint">
      <span class="k">&#9679;</span>
      <span>What the other party chooses to pay is not shared with you. If they never pay their half, you can come back and cover the balance to release the agreement &mdash; and recover it from them under clause 5 of the terms.</span>
    </div>

    <button class="btn btn-primary btn-block" type="button" id="feeOpen">Continue to payment</button>
  </form>

  <p class="note">The service charge is payable because a settlement was reached. It is not a payment for the document, and it is not refundable if the other party later declines to sign.</p>
</div>

<div class="rel-veil" id="relModal" hidden>
  <div class="rel" role="dialog" aria-modal="true" aria-labelledby="relTitle">
    <div class="mi">&#10003;</div>
    <h3 id="relTitle">Release the settlement agreement?</h3>
    <p>Once the service charge is paid in full, a link to the executable settlement agreement is emailed to <strong>both parties</strong>. This cannot be undone.</p>
    <p>Nothing is binding until both parties sign it.</p>
    <label class="consent">
      <input type="checkbox" id="relConsent" />
      <span>I authorise MidBid to charge my card <strong id="relAmount"><%= pay.fee.halfLabel %></strong> and release the agreement.</span>
    </label>
    <div class="rel-actions">
      <button class="btn btn-ghost" type="button" id="relCancel">Not yet</button>
      <button class="btn btn-primary" type="button" id="relGo" disabled>Pay <span id="relAmount2"><%= pay.fee.halfLabel %></span></button>
    </div>
  </div>
</div>

<script>
(function(){
  var form=document.getElementById('feeForm');
  if(!form) return;
  var HALF=<%- JSON.stringify(pay.fee.halfLabel) %>, FULL=<%- JSON.stringify(pay.fee.outstandingLabel) %>;
  var modal=document.getElementById('relModal'), consent=document.getElementById('relConsent'),
      go=document.getElementById('relGo'), cancel=document.getElementById('relCancel'),
      open=document.getElementById('feeOpen'),
      a1=document.getElementById('relAmount'), a2=document.getElementById('relAmount2'),
      cs=document.getElementById('choiceSplit'), cf=document.getElementById('choiceFull');

  function picked(){ var el=form.querySelector('input[name=choice]:checked'); return el?el.value:'split'; }
  function paint(){
    var full = picked()==='full';
    cs.classList.toggle('on',!full); cf.classList.toggle('on',full);
    a1.textContent = a2.textContent = full?FULL:HALF;
  }
  form.addEventListener('change',paint); paint();

  open.addEventListener('click',function(){ consent.checked=false; go.disabled=true; modal.hidden=false; });
  cancel.addEventListener('click',function(){ modal.hidden=true; });
  modal.addEventListener('click',function(e){ if(e.target===modal) modal.hidden=true; });
  consent.addEventListener('change',function(){ go.disabled=!consent.checked; });
  go.addEventListener('click',function(){ go.disabled=true; go.textContent='Processing…'; form.submit(); });
})();
</script>
<% } %>

<!-- Settlement details + e-signature hand-off -->
<div class="mb-modal" id="settleModal" hidden>
  <div class="mb-modal-back" id="settleBack"></div>
  <div class="mb-modal-card" role="dialog" aria-modal="true" aria-labelledby="settleTitle">
    <button class="mb-modal-x" id="settleClose" type="button" aria-label="Close">×</button>

    <div id="settleStep1" <%= myDetailsDone ? 'hidden' : '' %>>
      <div class="mb-modal-badge">Agreed</div>
      <h2 id="settleTitle">Your settlement is agreed</h2>
      <p class="mb-modal-sub">Both sides have settled. Add your details below so your settlement agreement names you correctly.</p>

      <label for="pdName">Full name</label>
      <input id="pdName" type="text" maxlength="200" placeholder="As it should appear on the agreement" />

      <label for="pdCompany">Company name <span class="opt">(optional)</span></label>
      <input id="pdCompany" type="text" maxlength="200" placeholder="e.g. Northgate Interiors Ltd" />

      <label for="pdAddress">Address</label>
      <textarea id="pdAddress" rows="3" maxlength="500" placeholder="Street, city, postcode"></textarea>

      <div class="mb-modal-err" id="pdErr" hidden></div>
      <button class="mb-modal-go" id="pdSave" type="button">Save my details</button>
      <p class="mb-modal-fine">Used only to identify the parties on the settlement agreement.</p>
    </div>

    <div id="settleStep2" <%= myDetailsDone ? '' : 'hidden' %>>
      <div class="mb-modal-badge ok">Details saved</div>

      <div id="pdWait" <%= bothDetailsDone ? 'hidden' : '' %>>
        <h2>Waiting for the other side</h2>
        <p class="mb-modal-sub">Thanks — your details are recorded. As soon as the other party adds theirs, your settlement agreement is ready to release.</p>
      </div>

      <div id="pdReady" <%= bothDetailsDone ? '' : 'hidden' %>>
        <% if (pay && pay.enabled && !pay.released) { %>
          <h2>One step to release</h2>
          <p class="mb-modal-sub">Both sides have provided their details. Your settlement agreement is released as soon as the MidBid service charge is paid. Close this and choose how to cover it.</p>
          <button class="mb-modal-go" type="button" onclick="document.getElementById('settleModal').hidden=true;document.body.style.overflow='';var f=document.getElementById('feeForm');if(f)f.scrollIntoView({behavior:'smooth'})">Continue to the service charge →</button>
        <% } else { %>
          <h2>Your agreement is ready</h2>
          <p class="mb-modal-sub">Both sides have provided their details and the service charge is settled. Your executable settlement agreement is ready to view and download.</p>
          <a class="mb-modal-go" href="/cases/<%= c.id %>/agreement" target="_blank" rel="noopener">View &amp; download the agreement →</a>
        <% } %>
      </div>
      <p class="mb-modal-fine">MidBid never holds the settlement money. You and the other party settle the agreed sum directly.</p>
    </div>
  </div>
</div>

<p style="margin-top:1.2rem"><a href="/dashboard">← Back to my cases</a></p>

<script>
  var AMOUNT = <%= c.amount %>;
  var CUR = { symbol: <%- JSON.stringify(cur.symbol) %>, locale: <%- JSON.stringify(cur.locale) %> };
  var CASE_ID = <%= c.id %>;
  var ROLE = '<%= role %>';                       // 'claim' (wants high) or 'resp' (wants low)
  var INIT = <%- JSON.stringify({ mine: status.mine, close: !!status.close, prox: status.prox, mineApproved: !!status.mineApproved, otherApproved: !!status.otherApproved, state: status.state }) %>;

  var track=document.getElementById('track'), you=document.getElementById('you'), ring=document.getElementById('ring');
  var hIdeal=document.getElementById('hIdeal'), hFair=document.getElementById('hFair'), band=document.getElementById('band');
  var figNum=document.getElementById('figNum'), figRole=document.getElementById('figRole'), pops=document.getElementById('pops');
  var vIdeal=document.getElementById('vIdeal'), vFair=document.getElementById('vFair'), vRes=document.getElementById('vRes');
  var kIdeal=document.getElementById('kIdeal'), kRes=document.getElementById('kRes');
  var saveBtn=document.getElementById('saveBtn'), saveHint=document.getElementById('saveHint');
  var btn=document.getElementById('approve'), approveLbl=document.getElementById('approveLbl');
  var coachBox=document.getElementById('coachBox'), coachText=document.getElementById('coachText');
  var proxFill=document.getElementById('proxFill'), proxText=document.getElementById('proxText');
  var medWrap=document.getElementById('medWrap'), chips=document.getElementById('chips');

  // Role-aware labels. Both roles read left->right as [low, mid, high].
  var LBL = ROLE==='claim'
    ? { res:'The least you’ll accept', fair:'Your target figure', ideal:'Your ideal outcome', kIdeal:'Ideal', kRes:'Walk-away' }
    : { res:'The most you’ll pay',     fair:'Your target figure', ideal:'Your ideal outcome', kIdeal:'Ideal', kRes:'Walk-away' };
  kIdeal.textContent=LBL.kIdeal; kRes.textContent=LBL.kRes;

  // slot fractions, always lo <= mid <= hi (left to right on the track)
  var MINGAP=0.015, lo, mid, hi;
  function fracFromVal(v){ return Math.max(0,Math.min(1, v/AMOUNT)); }
  if (INIT.mine && INIT.mine.reservation!=null){
    var a=INIT.mine;
    if (ROLE==='claim'){ lo=fracFromVal(a.reservation); mid=fracFromVal(a.fair!=null?a.fair:a.reservation); hi=fracFromVal(a.ideal!=null?a.ideal:a.fair); }
    else { hi=fracFromVal(a.reservation); mid=fracFromVal(a.fair!=null?a.fair:a.reservation); lo=fracFromVal(a.ideal!=null?a.ideal:a.fair); }
  } else {
    if (ROLE==='claim'){ lo=0.40; mid=0.60; hi=0.80; } else { lo=0.20; mid=0.40; hi=0.60; }
  }
  function order(){ if(mid<lo+MINGAP)mid=lo+MINGAP; if(hi<mid+MINGAP)hi=mid+MINGAP; if(hi>1){hi=1; if(mid>hi-MINGAP)mid=hi-MINGAP; if(lo>mid-MINGAP)lo=mid-MINGAP;} if(lo<0)lo=0; }

  // map slots -> meaning
  function resFrac(){ return ROLE==='claim'?lo:hi; }
  function idealFrac(){ return ROLE==='claim'?hi:lo; }
  function anchorsGBP(){
    return { ideal:Math.round(idealFrac()*AMOUNT), fair:Math.round(mid*AMOUNT), reservation:Math.round(resFrac()*AMOUNT) };
  }

  var dragging=null, lastPopX=null, locked=false;
  var gClose=INIT.close, phase='negotiate', t=0, btnX=0, btnY=0, btnW=120, btnH=36, circleStart=0;

  function gbp(n){ return Number(n).toLocaleString(CUR.locale); }

  function makeSnake(hex, glow){
    var layer=document.createElement('div'); layer.className='mb-snake'; track.appendChild(layer);
    var segs=[];
    for(var i=0;i<8;i++){
      var s=document.createElement('span'); s.className='seg'; var size=14-i;
      s.style.width=size+'px'; s.style.height=size+'px'; s.style.background=hex; s.style.opacity=(1-i*0.1).toFixed(2);
      s.style.boxShadow='0 0 '+(10-i)+'px '+Math.max(0.5,(3-i*0.25)).toFixed(2)+'px '+glow.replace('A',(0.5-i*0.045).toFixed(2));
      layer.appendChild(s); segs.push(s);
    }
    return {layer:layer, segs:segs, hist:[], x:0.5*520, y:0};
  }
  var yellow=makeSnake('#f5b400','rgba(245,180,0,A)');
  var blue=makeSnake('#2b54e6','rgba(43,84,230,A)'); blue.layer.style.display='none';

  function placeAll(){
    order();
    you.style.left=(resFrac()*100)+'%';
    hFair.style.left=(mid*100)+'%';
    hIdeal.style.left=(idealFrac()*100)+'%';
    band.style.left=(lo*100)+'%';
    band.style.width=((hi-lo)*100)+'%';
    var a=anchorsGBP();
    vIdeal.textContent=gbp(a.ideal); vFair.textContent=gbp(a.fair); vRes.textContent=gbp(a.reservation);
    you.setAttribute('aria-valuenow',a.reservation);
  }
  function headline(slot){
    var a=anchorsGBP();
    if(slot==='ideal'){ figNum.textContent=gbp(a.ideal); figRole.textContent=LBL.ideal; }
    else if(slot==='res'){ figNum.textContent=gbp(a.reservation); figRole.textContent=LBL.res; }
    else { figNum.textContent=gbp(a.fair); figRole.textContent=LBL.fair; }
    [].forEach.call(chips.children,function(ch){ ch.classList.toggle('sel', ch.getAttribute('data-slot')===slot); });
  }
  // chip click jumps the headline to that figure
  [].forEach.call(chips.children,function(ch){ ch.addEventListener('click',function(){ headline(ch.getAttribute('data-slot')); }); });

  function setCoach(tone,text){
    if(!coachBox)return;
    if(!text){ coachBox.style.display='none'; return; }
    var changed=coachText.textContent!==text;
    coachText.textContent=text; coachBox.className='coach tone-'+(tone||'idle'); coachBox.style.display='flex';
    if(changed){ coachBox.classList.remove('pop'); void coachBox.offsetWidth; coachBox.classList.add('pop'); }
  }
  function setProx(p){
    if(!p){ proxFill.style.width='0%'; proxText.textContent=''; return; }
    proxFill.style.width=Math.round((p.fill||0)*100)+'%';
    proxFill.className='mb-prox-fill lvl-'+(p.level||'far');
    proxText.textContent=p.text||'';
    proxText.classList.toggle('hot', p.level==='near');
  }
  function setApprove(state){
    btn.classList.remove('ready');
    if(state==='ready'){ btn.classList.add('ready'); approveLbl.textContent='Settle'; }
    else if(state==='waiting'){ approveLbl.textContent='Waiting for the other side…'; }
    else if(state==='green'){ btn.classList.add('is-green'); approveLbl.textContent='Settle'; }
    else { approveLbl.textContent='Settle'; }
  }

  function applyStatus(s){
    if(!s) return;
    gClose = !!s.close;
    if(s.prox) setProx(s.prox);
    if(locked) return;
    if(s.state==='settled'){ runSeal(); return; }
    if(s.mineApproved){ phase='mine'; setApprove('waiting'); setCoach('success',"You've approved — waiting for the other side to accept."); ring.style.animationDuration='2.4s'; return; }
    phase='negotiate';
    if(s.close && s.otherApproved){ setApprove('ready'); setCoach('success',"The other side has approved — approve to lock it in."); }
    else if(s.close){ setApprove('ready'); setCoach('success',"You're within range of each other — either side can approve to settle."); }
    else { setApprove('idle'); if(s.coach) setCoach(s.coach.tone, s.coach.text); }
  }

  function step(sn,tx,ty,e){ sn.x+=(tx-sn.x)*e; sn.y+=(ty-sn.y)*e; sn.hist.unshift({x:sn.x,y:sn.y}); if(sn.hist.length>70)sn.hist.pop(); }
  function draw(sn){ for(var i=0;i<sn.segs.length;i++){ var h=sn.hist[Math.min(i*5,sn.hist.length-1)]; if(!h)continue; sn.segs[i].style.left=h.x+'px'; sn.segs[i].style.top='calc(50% + '+h.y+'px)'; } }

  function frame(){
    t+=0.025; var W=track.clientWidth||520;
    if(phase==='travel'){
      var Rx=btnW/2+12;
      step(blue, btnX-Rx, btnY, 0.05); draw(blue);
      step(yellow, btnX+Rx, btnY, 0.05); draw(yellow);
    } else if(phase==='circle'){
      var rx=btnW/2+12, ry=btnH/2+12, a=(performance.now()-circleStart)/1000*4.0;
      var wB=Math.sin(a*3)*3, wY=Math.sin(a*3+1.2)*3, ba=Math.PI+a, ya=a;
      step(blue, btnX+(rx+wB)*Math.cos(ba), btnY+(ry+wB)*Math.sin(ba), 0.42); draw(blue);
      step(yellow, btnX+(rx+wY)*Math.cos(ya), btnY+(ry+wY)*Math.sin(ya), 0.42); draw(yellow);
    } else if(phase!=='agreed'){
      var nx=Math.max(0.02,Math.min(0.98, 0.5 + Math.sin(t*0.32)*0.42));
      step(yellow, nx*W, Math.sin(nx*W*0.05 + t*1.4)*7, 0.12); draw(yellow);
    }
    requestAnimationFrame(frame);
  }

  function spawnPop(px){
    for(var i=0;i<2;i++){
      var d=document.createElement('span'); d.className='pp'; var bl=Math.random()<0.5;
      d.style.background=bl?'#2b54e6':'#5b7bf0'; d.style.boxShadow='0 0 7px 1px '+(bl?'rgba(43,84,230,.5)':'rgba(91,123,240,.5)');
      d.style.left=(px+(Math.random()*16-8))+'px'; d.style.top='50%'; d.style.transform='translate(-50%,-50%)'; pops.appendChild(d);
      (function(el){var up=18+Math.random()*10;
        requestAnimationFrame(function(){el.style.transition='transform .3s cubic-bezier(.3,1.25,.5,1)';el.style.transform='translate(-50%,calc(-50% - '+up+'px))';});
        setTimeout(function(){el.style.transform='translate(-50%,calc(-50% - 9px))';},320);
        setTimeout(function(){el.style.transition='opacity .45s';el.style.opacity='0';},980);
        setTimeout(function(){el.remove();},1480);})(d);
    }
  }
  function burstAt(cx,cy){
    for(var i=0;i<22;i++){
      var d=document.createElement('span'); d.className='pp'; var bl=(i%2)===0;
      d.style.background=bl?'#2b54e6':'#23a259'; d.style.boxShadow='0 0 8px 2px '+(bl?'rgba(43,84,230,.5)':'rgba(35,162,89,.55)');
      d.style.left=cx+'px'; d.style.top='calc(50% + '+cy+'px)'; d.style.transform='translate(-50%,-50%)'; pops.appendChild(d);
      (function(el){var ang=Math.random()*Math.PI*2,dist=30+Math.random()*55;var tx=Math.cos(ang)*dist,ty=Math.sin(ang)*dist;
        requestAnimationFrame(function(){el.style.transition='transform .9s cubic-bezier(.2,.7,.3,1), opacity .9s';el.style.transform='translate(calc(-50% + '+tx+'px),calc(-50% + '+(cy+ty)+'px)) scale(.5)';el.style.opacity='0';});
        setTimeout(function(){el.remove();},950);})(d);
    }
  }

  function measureBtn(){
    var tr=track.getBoundingClientRect(), br=btn.getBoundingClientRect();
    btnX=(br.left+br.width/2)-tr.left; btnY=(br.top+br.height/2)-(tr.top+tr.height/2); btnW=br.width; btnH=br.height;
  }
  function runSeal(){
    if(locked) return; locked=true;
    saveBtn.style.display='none';
    measureBtn();
    var W=track.clientWidth||520;
    you.style.display='none'; hFair.style.display='none'; hIdeal.style.display='none';
    blue.layer.style.display='block'; blue.x=resFrac()*W; blue.y=0; blue.hist=[];
    setCoach('success',"Both sides approved — preparing your agreement…");
    phase='travel';
    setTimeout(function(){ phase='circle'; circleStart=performance.now(); },1100);
    setTimeout(finalizeAgreed,2700);
  }
  function finalizeAgreed(){
    phase='agreed';
    setApprove('green');
    burstAt(btnX,btnY);
    setCoach('success',"Agreed! The figure is locked in by both sides.");
    var esc=document.getElementById('escalate'); if(esc) esc.style.display='none';
    setTimeout(function(){ blue.layer.style.opacity='0'; yellow.layer.style.opacity='0'; },350);
    // Reload so the settled view renders the agreement / success-fee step from the server.
    setTimeout(function(){ location.reload(); },2100);
  }
  function finalizeNow(){
    locked=true; phase='agreed';
    saveBtn.style.display='none';
    var esc=document.getElementById('escalate'); if(esc) esc.style.display='none';
    you.style.display='none'; hFair.style.display='none'; hIdeal.style.display='none';
    yellow.layer.style.display='none'; blue.layer.style.display='none';
    setApprove('green');
    setCoach('success',"Agreed. This figure is locked in by both sides.");
    medWrap.classList.add('show');
  }

  function postForm(url,body){ return fetch(url,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:body}).then(function(r){return r.json();}); }

  /* ===== Settle modal: details for the agreement, then service charge ===== */
  (function(){
    var modal=document.getElementById('settleModal');
    if(!modal) return;
    var openBtn=document.getElementById('settleBtn');
    var back=document.getElementById('settleBack'), closeBtn=document.getElementById('settleClose');
    var step1=document.getElementById('settleStep1'), step2=document.getElementById('settleStep2');
    var company=document.getElementById('pdCompany'), address=document.getElementById('pdAddress');
    var fullName=document.getElementById('pdName');
    var save=document.getElementById('pdSave'), err=document.getElementById('pdErr');
    var wait=document.getElementById('pdWait'), ready=document.getElementById('pdReady');
    var MY_DETAILS_DONE = <%= myDetailsDone ? 'true' : 'false' %>;

    function open(){ modal.hidden=false; document.body.style.overflow='hidden'; var f=step1.hidden?null:fullName; if(f) setTimeout(function(){f.focus();},80); }
    function close(){ modal.hidden=true; document.body.style.overflow=''; }
    if(openBtn) openBtn.addEventListener('click',open);
    // After settlement the single green "Settle" button opens the details modal.
    var SETTLED = <%= c.status === 'settled' ? 'true' : 'false' %>;
    var mainBtn=document.getElementById('approve');
    if(SETTLED && mainBtn){ mainBtn.style.cursor='pointer'; mainBtn.addEventListener('click',open); }
    if(back) back.addEventListener('click',close);
    if(closeBtn) closeBtn.addEventListener('click',close);
    document.addEventListener('keydown',function(e){ if(e.key==='Escape'&&!modal.hidden) close(); });

    function fail(msg,el){ err.textContent=msg; err.hidden=false; if(el) el.focus(); }
    if(save) save.addEventListener('click',function(){
      var n=(fullName.value||'').trim(), a=(address.value||'').trim();
      if(n.length<2){ return fail('Please enter your full name as it should appear on the agreement.', fullName); }
      if(a.length<6){ return fail('Please enter an address so the agreement can name you correctly.', address); }
      err.hidden=true; save.disabled=true; save.textContent='Saving…';
      var body='full_name='+encodeURIComponent(n)
             +'&company='+encodeURIComponent((company.value||'').trim())
             +'&address='+encodeURIComponent(a);
      postForm('/cases/'+CASE_ID+'/party-details',body)
        .then(function(r){
          if(!r||!r.ok) throw new Error((r&&r.error)||'failed');
          step1.hidden=true; step2.hidden=false;
          if(r.bothIn){
            if(wait) wait.hidden=true;
            if(ready) ready.hidden=false;
          }
        })
        .catch(function(){ save.disabled=false; save.textContent='Save my details'; fail('Could not save your details — please try again.'); });
    });

    // Pop the modal automatically the moment the case becomes agreed — but only
    // once the Settle step is actually available (i.e. any success fee is paid).
    window.mbOpenSettleModal=function(){ if(openBtn && modal.hidden) setTimeout(open,900); };
    if(openBtn && MY_DETAILS_DONE===false && INIT.state==='settled') setTimeout(open,600);

    // While we wait on the other side, watch for their details and reveal the
    // "ready to release" step (service charge, then agreement) automatically.
    function unlockReady(){
      if(wait) wait.hidden=true;
      if(ready) ready.hidden=false;
    }
    var watch=setInterval(function(){
      // Only poll while we're actually parked on the waiting screen.
      if(!wait || wait.hidden || step2.hidden) { clearInterval(watch); return; }
      fetch('/cases/'+CASE_ID+'/status').then(function(r){return r.json();}).then(function(s){
        if(s && s.bothDetailsDone){ unlockReady(); clearInterval(watch); }
      }).catch(function(){});
    },6000);
  })();

  function saveFigures(){
    var a=anchorsGBP();
    saveBtn.disabled=true; saveHint.textContent='Saving…';
    postForm('/cases/'+CASE_ID+'/bid','ideal='+a.ideal+'&fair='+a.fair+'&reservation='+a.reservation)
      .then(function(s){ applyStatus(s); saveBtn.disabled=false; saveHint.textContent='Saved.'; setTimeout(function(){saveHint.textContent='';},1500); })
      .catch(function(){ saveBtn.disabled=false; saveHint.textContent='Could not save — try again.'; });
  }
  function approve(){
    if(phase!=='negotiate'||locked) return;
    if(!gClose){ setCoach('warning',"You're not close enough yet — save a closer walk-away figure first."); return; }
    btn.classList.remove('ready'); setApprove('waiting'); setCoach('success',"You've approved — letting the other side know…");
    postForm('/cases/'+CASE_ID+'/approve','')
      .then(function(s){ applyStatus(s); })
      .catch(function(){ setCoach('warning',"Could not record your approval — try again."); setApprove('ready'); });
  }

  // ---- three-handle dragging with ordering constraints ----
  function clampSlot(slot,p){
    if(slot==='lo')  return Math.max(0, Math.min(p, mid-MINGAP));
    if(slot==='mid') return Math.max(lo+MINGAP, Math.min(p, hi-MINGAP));
    return Math.max(mid+MINGAP, Math.min(p, 1));   // 'hi'
  }
  function slotForHandle(el){
    if(el===hFair) return 'mid';
    if(el===you) return ROLE==='claim'?'lo':'hi';
    if(el===hIdeal) return ROLE==='claim'?'hi':'lo';
    return null;
  }
  function chipSlotFor(slot){
    if(slot==='mid') return 'fair';
    if(slot===(ROLE==='claim'?'lo':'hi')) return 'res';
    return 'ideal';
  }
  function setSlot(slot,p){
    if(slot==='lo')lo=clampSlot('lo',p); else if(slot==='mid')mid=clampSlot('mid',p); else hi=clampSlot('hi',p);
    placeAll(); headline(chipSlotFor(slot));
  }
  function nearestHandle(p){
    var cands=[{el:you,f:resFrac()},{el:hFair,f:mid},{el:hIdeal,f:idealFrac()}];
    cands.sort(function(a,b){return Math.abs(a.f-p)-Math.abs(b.f-p);});
    return cands[0].el;
  }
  function pFromClientX(clientX){ var r=track.getBoundingClientRect(); return Math.max(0,Math.min(1,(clientX-r.left)/r.width)); }
  function down(el,e){
    if(locked||phase==='agreed') return;
    dragging=el; lastPopX=null; el.classList.add('live');
    if(el.setPointerCapture&&e.pointerId!=null){try{el.setPointerCapture(e.pointerId);}catch(_){}}
    var p=pFromClientX(e.clientX); var slot=slotForHandle(el);
    var px=p*(track.getBoundingClientRect().width);
    if(lastPopX===null||Math.abs(px-lastPopX)>26){ spawnPop(px); lastPopX=px; }
    setSlot(slot,p); e.preventDefault();
  }
  you.addEventListener('pointerdown',function(e){down(you,e);});
  hFair.addEventListener('pointerdown',function(e){down(hFair,e);});
  hIdeal.addEventListener('pointerdown',function(e){down(hIdeal,e);});
  track.addEventListener('pointerdown',function(e){ if(e.target.closest('.mb-you,.mb-h'))return; down(nearestHandle(pFromClientX(e.clientX)),e); });
  window.addEventListener('pointermove',function(e){
    if(!dragging) return;
    var p=pFromClientX(e.clientX), slot=slotForHandle(dragging);
    var px=p*(track.getBoundingClientRect().width);
    if(lastPopX===null||Math.abs(px-lastPopX)>26){ spawnPop(px); lastPopX=px; }
    setSlot(slot,p);
  });
  window.addEventListener('pointerup',function(){ if(dragging){dragging.classList.remove('live'); dragging=null;} lastPopX=null; });

  // keyboard for the reservation hub
  you.tabIndex=0; you.setAttribute('role','slider'); you.setAttribute('aria-label','Your walk-away figure'); you.setAttribute('aria-valuemin',0); you.setAttribute('aria-valuemax',AMOUNT);
  you.addEventListener('keydown',function(e){
    if(locked)return; var slot=ROLE==='claim'?'lo':'hi'; var cur=resFrac();
    if(e.key==='ArrowLeft'||e.key==='ArrowDown'){ setSlot(slot,cur-0.02); spawnPop(resFrac()*track.clientWidth); e.preventDefault(); }
    if(e.key==='ArrowRight'||e.key==='ArrowUp'){ setSlot(slot,cur+0.02); spawnPop(resFrac()*track.clientWidth); e.preventDefault(); }
  });

  if(saveBtn) saveBtn.addEventListener('click',saveFigures);
  btn.addEventListener('click',approve);

  var mediatorBtn=document.getElementById('mediatorBtn'), mediatorLbl=document.getElementById('mediatorLbl');
  if(mediatorBtn) mediatorBtn.addEventListener('click',function(){
    mediatorBtn.disabled=true; mediatorLbl.textContent='Requesting…';
    postForm('/cases/'+CASE_ID+'/mediator','')
      .then(function(r){ mediatorLbl.textContent='✓ Human mediator requested'; })
      .catch(function(){ mediatorBtn.disabled=false; mediatorLbl.textContent='Request a human mediator'; });
  });

  var copyBtn=document.getElementById('copyBtn');
  if(copyBtn) copyBtn.addEventListener('click',function(){ var x=document.getElementById('inviteBox').textContent.trim(); navigator.clipboard.writeText(x).then(function(){ copyBtn.textContent='Copied!'; setTimeout(function(){copyBtn.textContent='Copy link';},1500); }); });

  // Poll so the other side's moves and approval show up here.
  setInterval(function(){
    if(locked) return;
    fetch('/cases/'+CASE_ID+'/status').then(function(r){return r.json();}).then(function(s){ if(s&&s.state) applyStatus(s); }).catch(function(){});
  },4000);

  placeAll();
  headline('fair');
  setProx(INIT.prox);
  if(INIT.state==='settled'){ finalizeNow(); }
  else { applyStatus({state:INIT.state, close:INIT.close, prox:INIT.prox, mineApproved:INIT.mineApproved, otherApproved:INIT.otherApproved, coach:null}); }
  requestAnimationFrame(frame);
</script>
<%- include('partials/foot') %>

        </div>
        <div class="role resp">
          <div class="who"><span class="pip"></span> You owe money</div>
          <div class="lbl">The most you'll pay</div>
          <div class="fig" id="respFig">£30,000</div>
          <input class="rng resp" id="respRange" type="range" min="0" max="80000" step="500" value="30000" aria-label="The most you will pay" />

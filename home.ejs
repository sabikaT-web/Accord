<script>
  var nav=document.getElementById('nav');
  window.addEventListener('scroll',function(){ if(window.scrollY>8){nav.classList.add('scrolled');}else{nav.classList.remove('scrolled');} },{passive:true});

  var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(!reduce && 'IntersectionObserver' in window){
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){
          e.target.classList.add('in');
          if(e.target.classList.contains('step')&&e.target.classList.contains('active')){
            var bar=e.target.querySelector('.bar'); if(bar){bar.style.width='100%';}
          }
          io.unobserve(e.target);
        }
      });
    },{threshold:0.12,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
  } else { document.querySelectorAll('.reveal').forEach(function(el){el.classList.add('in');}); }

  var menuBtn=document.getElementById('menuBtn');
  if(menuBtn){
    menuBtn.addEventListener('click',function(){
      var links=document.querySelector('.nav-links');
      if(links.style.display==='flex'){links.style.display='';}
      else{
        links.style.display='flex';links.style.position='absolute';links.style.top='72px';links.style.left='0';links.style.right='0';
        links.style.flexDirection='column';links.style.gap='0';links.style.background='var(--ground)';
        links.style.borderBottom='1px solid var(--line)';links.style.padding='10px 24px 18px';
        links.querySelectorAll('a').forEach(function(a){a.style.padding='12px 0';});
      }
    });
  }

  /* ===== The settlement scale ===== */
  (function(){
    var DISPUTED=80000;
    var THRESHOLD=0.10; // within 10% of the amount in dispute
    var claimR=document.getElementById('claimRange');
    var respR=document.getElementById('respRange');
    var claimFig=document.getElementById('claimFig');
    var respFig=document.getElementById('respFig');
    var markClaim=document.getElementById('markClaim');
    var markResp=document.getElementById('markResp');
    var bubClaim=document.getElementById('bubClaim');
    var bubResp=document.getElementById('bubResp');
    var zone=document.getElementById('zone');
    var track=document.getElementById('track');
    var status=document.getElementById('status');
    var sTitle=document.getElementById('statusTitle');
    var sSub=document.getElementById('statusSub');
    var sGlyph=document.getElementById('statusGlyph');

    var gbp=function(n){return '£'+Math.round(n).toLocaleString('en-GB');};
    var ICON_INFO='<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M12 8v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="16" r="1" fill="currentColor"/></svg>';
    var ICON_NEAR='<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    var ICON_DEAL='<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4 10-11" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>';

    function render(){
      var claim=+claimR.value, resp=+respR.value;
      var cP=claim/DISPUTED*100, rP=resp/DISPUTED*100;
      claimFig.textContent=gbp(claim); respFig.textContent=gbp(resp);
      bubClaim.textContent=gbp(claim); bubResp.textContent=gbp(resp);
      markClaim.style.left=cP+'%'; markResp.style.left=rP+'%';

      var lo=Math.min(cP,rP), hi=Math.max(cP,rP);
      zone.style.left=lo+'%'; zone.style.width=(hi-lo)+'%';

      var gap=claim-resp;
      track.classList.remove('close','deal'); status.classList.remove('close','deal');

      if(gap<=0){
        var settle=Math.round((claim+resp)/2/100)*100;
        track.classList.add('deal'); status.classList.add('deal');
        sGlyph.innerHTML=ICON_DEAL;
        sTitle.textContent='Settled at '+gbp(settle);
        sSub.textContent='Your figures met. This becomes a binding, enforceable agreement.';
      } else if(gap<=THRESHOLD*DISPUTED){
        track.classList.add('close'); status.classList.add('close');
        sGlyph.innerHTML=ICON_NEAR;
        sTitle.textContent="Within 10% — you're close";
        sSub.textContent='A small move from either side could close the gap.';
      } else {
        sGlyph.innerHTML=ICON_INFO;
        sTitle.textContent='No signal yet';
        sSub.textContent='Keep adjusting — nothing leaks while you\u2019re apart.';
      }
    }
    claimR.addEventListener('input',render);
    respR.addEventListener('input',render);
    document.querySelectorAll('.preset').forEach(function(b){
      b.addEventListener('click',function(){
        claimR.value=b.getAttribute('data-claim');
        respR.value=b.getAttribute('data-resp');
        render();
      });
    });
    render();
  })();

</script>

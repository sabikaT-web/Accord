<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MidBid — Settle stuck money, blind</title>
<meta name="description" content="MidBid is online mediation for stuck money. Each side privately names a figure, nobody sees the other's, and the scale only signals when you're within reach of a deal." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Hanken+Grotesk:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root{
    --ground:#F5F7FB; --ground-2:#EAEFF7; --paper:#FFFFFF;
    --ink:#1E2A45; --ink-soft:#586079;
    --teal:#2F6BFF; --teal-deep:#16306B;
    --ochre:#F5B312; --ochre-soft:#FAD56A;
    --go:#15B877;                 /* the "you're close / deal" signal */
    --go-soft:#7FE0AC;
    --line:#DCE3EF; --signal:#B5790F;
    --maxw:1180px; --r:14px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--ground);color:var(--ink);font-family:"Hanken Grotesk",system-ui,sans-serif;font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}
  section{position:relative}
  a{color:inherit;text-decoration:none}

  .display{font-family:"Fraunces",Georgia,serif;font-weight:400;line-height:1.02;letter-spacing:-.015em}
  .eyebrow{font-family:"Spline Sans Mono",monospace;font-size:.74rem;letter-spacing:.22em;text-transform:uppercase;color:var(--signal);font-weight:500}
  h2.display{font-size:clamp(1.9rem,3.8vw,2.85rem)}
  h3{font-family:"Fraunces",serif;font-weight:500;font-size:1.35rem;line-height:1.15;letter-spacing:-.01em}
  p.lead{font-size:1.12rem;color:var(--ink-soft)}

  .btn{display:inline-flex;align-items:center;gap:.55em;font-weight:600;font-size:.98rem;padding:.85em 1.4em;border-radius:999px;border:1px solid transparent;cursor:pointer;transition:transform .18s ease,background .18s ease,box-shadow .18s ease,color .18s ease;white-space:nowrap}
  .btn-primary{background:var(--teal-deep);color:#F4F2EB}
  .btn-primary:hover{background:var(--teal);transform:translateY(-2px);box-shadow:0 10px 24px -12px rgba(30,42,69,.7)}
  .btn-ghost{background:transparent;color:var(--ink);border-color:var(--line)}
  .btn-ghost:hover{border-color:var(--ink);transform:translateY(-2px)}
  .btn .arrow{transition:transform .18s ease}
  .btn:hover .arrow{transform:translateX(3px)}

  header.nav{position:sticky;top:0;z-index:50;background:color-mix(in srgb,var(--ground) 86%,transparent);backdrop-filter:blur(10px);border-bottom:1px solid transparent;transition:border-color .3s ease}
  header.nav.scrolled{border-color:var(--line)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;height:72px}
  .brand{display:flex;align-items:center;gap:.6em;font-family:"Fraunces",serif;font-weight:500;font-size:1.32rem;letter-spacing:-.01em}
  .brand .mark{width:26px;height:26px;flex:none}
  .nav-links{display:flex;align-items:center;gap:2rem}
  .nav-links a{font-size:.95rem;color:var(--ink-soft);font-weight:500;transition:color .15s ease}
  .nav-links a:hover{color:var(--ink)}
  .nav-cta{display:flex;align-items:center;gap:.9rem}
  .nav-cta .signin{font-size:.95rem;font-weight:600}
  .menu-btn{display:none;background:none;border:1px solid var(--line);border-radius:10px;width:42px;height:42px;align-items:center;justify-content:center;cursor:pointer}
  .menu-btn span{display:block;width:18px;height:2px;background:var(--ink);position:relative}
  .menu-btn span::before,.menu-btn span::after{content:"";position:absolute;left:0;width:18px;height:2px;background:var(--ink)}
  .menu-btn span::before{top:-6px}.menu-btn span::after{top:6px}

  .hero{padding:clamp(48px,8vw,100px) 0 clamp(40px,6vw,72px);overflow:hidden}
  .hero-grid{position:relative}
  .seam{position:absolute;top:-40px;bottom:-40px;left:50%;width:1px;background:linear-gradient(var(--line),var(--ochre),var(--line));transform:translateX(-50%);opacity:0;animation:seamIn 1s ease .15s forwards}
  .seam::before,.seam::after{content:"";position:absolute;width:9px;height:9px;border-radius:50%;left:50%;transform:translateX(-50%)}
  .seam::before{top:38%;background:var(--teal)}
  .seam::after{top:62%;background:var(--ochre)}
  .hero-side{position:absolute;top:-200px;bottom:-200px;width:50vw;pointer-events:none;z-index:0}
  .hero-side.a{right:50%;background:radial-gradient(120% 80% at 100% 50%,rgba(47,107,255,.10),transparent 60%);transform:translateX(-40px);opacity:0;animation:slideIn 1.1s cubic-bezier(.2,.7,.2,1) .05s forwards}
  .hero-side.b{left:50%;background:radial-gradient(120% 80% at 0% 50%,rgba(245,179,18,.12),transparent 60%);transform:translateX(40px);opacity:0;animation:slideIn 1.1s cubic-bezier(.2,.7,.2,1) .05s forwards}
  .hero-content{position:relative;z-index:2;text-align:center;max-width:880px;margin:0 auto}
  .hero h1{font-size:clamp(2.4rem,6vw,4.4rem);margin:.5rem auto .9rem}
  .hero h1 .mid{position:relative;white-space:nowrap;color:var(--teal-deep)}
  .hero h1 .mid::after{content:"";position:absolute;left:0;right:0;bottom:.06em;height:.10em;background:var(--ochre-soft);border-radius:2px;z-index:-1;opacity:.55}
  .hero p.lead{max-width:620px;margin:0 auto 2rem}
  .hero-tagline{font-family:"Fraunces",serif;font-style:italic;font-size:clamp(1.05rem,2.1vw,1.35rem);color:var(--teal-deep);margin:.2rem auto 1.4rem;letter-spacing:-.01em}
  .hero-actions{display:flex;gap:.85rem;justify-content:center;flex-wrap:wrap}
  .hero-note{margin-top:1.6rem;font-size:.9rem;color:var(--ink-soft);display:flex;gap:.5em;align-items:center;justify-content:center}
  .hero-note .dot{width:7px;height:7px;border-radius:50%;background:var(--teal);box-shadow:0 0 0 4px rgba(47,107,255,.15)}

  .trust{position:sticky;top:71px;z-index:40;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--paper)}
  .trust-inner{display:flex;flex-wrap:wrap;gap:1rem 2.4rem;align-items:center;justify-content:center;padding:18px 0}
  .trust-item{display:flex;align-items:center;gap:.55em;font-size:.9rem;color:var(--ink-soft);font-weight:500}
  .trust-item svg{flex:none;color:var(--teal)}

  .band{padding:clamp(64px,9vw,112px) 0}
  .sec-head{max-width:680px;margin-bottom:2.6rem}
  .sec-head.center{margin-left:auto;margin-right:auto;text-align:center}
  .sec-head .eyebrow{display:inline-block;margin-bottom:.9rem}
  .sec-head p.lead{margin-top:.9rem}

  /* ============ THE SCALE (signature interactive) ============ */
  .scale-demo{background:color-mix(in srgb,var(--ground-2) 65%,var(--paper));border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .demo-card{background:var(--paper);border:1px solid var(--line);border-radius:20px;padding:clamp(22px,3.4vw,40px);box-shadow:0 30px 60px -45px rgba(30,42,69,.6)}
  .roles{display:grid;grid-template-columns:1fr 1fr;gap:1.4rem;margin-bottom:1.4rem}
  .role{padding:1.05rem 1.15rem;border-radius:12px;border:1px solid var(--line);background:var(--ground)}
  .role .who{display:flex;align-items:center;gap:.55em;font-family:"Spline Sans Mono",monospace;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;font-weight:500;margin-bottom:.5rem}
  .role .who .pip{width:11px;height:11px;border-radius:50%;flex:none}
  .role.claim .who .pip{background:var(--teal)} .role.claim .who{color:var(--teal)}
  .role.resp .who .pip{background:var(--ochre)} .role.resp .who{color:var(--ochre)}
  .role .lbl{font-size:.92rem;color:var(--ink-soft);margin-bottom:.55rem}
  .role .fig{font-family:"Fraunces",serif;font-size:1.7rem;font-weight:500;letter-spacing:-.01em;line-height:1;margin-bottom:.85rem}
  input[type=range].rng{-webkit-appearance:none;appearance:none;width:100%;height:6px;border-radius:999px;background:var(--line);outline:none;cursor:pointer}
  input[type=range].rng::-webkit-slider-thumb{-webkit-appearance:none;width:24px;height:24px;border-radius:50%;background:#fff;cursor:grab;box-shadow:0 2px 7px rgba(0,0,0,.22);transition:transform .12s ease}
  input[type=range].rng::-webkit-slider-thumb:active{cursor:grabbing;transform:scale(1.08)}
  input[type=range].rng::-moz-range-thumb{width:22px;height:22px;border-radius:50%;background:#fff;cursor:grab;box-shadow:0 2px 7px rgba(0,0,0,.22)}
  .rng.claim::-webkit-slider-thumb{border:4px solid var(--teal)} .rng.claim::-moz-range-thumb{border:4px solid var(--teal)}
  .rng.resp::-webkit-slider-thumb{border:4px solid var(--ochre)} .rng.resp::-moz-range-thumb{border:4px solid var(--ochre)}

  .track-shell{padding:8px 6px 0}
  .track{position:relative;height:16px;border-radius:999px;background:var(--ground-2);border:1px solid var(--line)}
  .track .zone{position:absolute;top:-1px;bottom:-1px;border-radius:999px;background:repeating-linear-gradient(45deg,rgba(88,96,121,.18),rgba(88,96,121,.18) 6px,transparent 6px,transparent 12px);transition:left .5s cubic-bezier(.2,.7,.2,1),width .5s cubic-bezier(.2,.7,.2,1),background .35s ease,box-shadow .35s ease}
  .track.close .zone{background:var(--go-soft);box-shadow:0 0 0 4px rgba(21,184,119,.16)}
  .track.deal .zone{background:var(--go)}
  .track .mark{position:absolute;top:50%;width:3px;height:42px;transform:translate(-50%,-50%);border-radius:3px;transition:left .5s cubic-bezier(.2,.7,.2,1)}
  .track .mark.claim{background:var(--teal)}
  .track .mark.resp{background:var(--ochre)}
  .track .mark .bubble{position:absolute;left:50%;transform:translateX(-50%);bottom:calc(100% + 8px);background:var(--paper);border:1px solid var(--line);border-radius:8px;padding:.2em .5em;font-family:"Spline Sans Mono",monospace;font-size:.7rem;white-space:nowrap;font-weight:500}
  .track .mark.resp .bubble{bottom:auto;top:calc(100% + 8px)}
  .ticks{display:flex;justify-content:space-between;margin-top:14px;font-family:"Spline Sans Mono",monospace;font-size:.68rem;color:var(--ink-soft);letter-spacing:.04em}

  .status{display:flex;align-items:center;gap:.8rem;margin-top:1.8rem;padding:1rem 1.2rem;border-radius:12px;border:1px solid var(--line);background:var(--ground);transition:background .35s ease,border-color .35s ease}
  .status.close{background:rgba(21,184,119,.10);border-color:rgba(21,184,119,.4)}
  .status.deal{background:rgba(21,184,119,.16);border-color:var(--go)}
  .status .glyph{width:40px;height:40px;border-radius:50%;flex:none;display:flex;align-items:center;justify-content:center;background:var(--line);color:var(--ink-soft);transition:background .35s ease,color .35s ease}
  .status.close .glyph,.status.deal .glyph{background:var(--go);color:#fff}
  .status .txt b{display:block;font-size:1.02rem}
  .status .txt span{font-size:.9rem;color:var(--ink-soft)}
  .presets{display:flex;gap:.6rem;flex-wrap:wrap;margin-top:1.4rem}
  .preset{font-family:"Hanken Grotesk",sans-serif;font-size:.86rem;font-weight:600;padding:.5em 1em;border-radius:999px;border:1px solid var(--line);background:transparent;color:var(--ink-soft);cursor:pointer;transition:border-color .15s ease,color .15s ease}
  .preset:hover{border-color:var(--ink);color:var(--ink)}
  .demo-foot{margin-top:1.5rem;font-size:.85rem;color:var(--ink-soft);display:flex;gap:.55em;align-items:flex-start}
  .demo-foot svg{flex:none;color:var(--teal);margin-top:.15em}

  /* ============ how it works ============ */
  .how{background:color-mix(in srgb,var(--ground-2) 70%,var(--paper));border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0}
  .step{padding:1.6rem 1.4rem 1.6rem 0;position:relative;border-top:2px solid var(--line)}
  .step:not(:last-child){margin-right:1.4rem}
  .step .num{font-family:"Spline Sans Mono",monospace;font-size:.8rem;color:var(--signal);font-weight:500;letter-spacing:.1em;margin-bottom:.9rem}
  .step.active .bar{position:absolute;top:-2px;left:0;height:2px;background:var(--ochre);width:0;transition:width 1.1s ease}
  .step h3{font-size:1.18rem;margin-bottom:.45rem}
  .step p{font-size:.95rem;color:var(--ink-soft)}

  /* ============ features ============ */
  .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem 2.2rem}
  .feat{padding-top:1.3rem;border-top:1px solid var(--line)}
  .feat .fi{color:var(--teal);margin-bottom:.7rem}
  .feat h3{font-size:1.1rem;margin-bottom:.35rem;font-family:"Hanken Grotesk",sans-serif;font-weight:700;letter-spacing:0}
  .feat p{font-size:.94rem;color:var(--ink-soft)}

  /* ============ stats ============ */
  .stats{background:linear-gradient(150deg,#1E2A45,#13203A);color:#E9EFEB;border-radius:24px;padding:clamp(34px,5vw,52px);position:relative;overflow:hidden}
  .stats::before{content:"";position:absolute;inset:0;background:radial-gradient(70% 120% at 85% 0%,rgba(245,179,18,.18),transparent 55%);pointer-events:none}
  .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;position:relative;z-index:1}
  .stat .n{font-family:"Fraunces",serif;font-size:clamp(2.2rem,4.4vw,3.1rem);font-weight:500;line-height:1;letter-spacing:-.02em}
  .stat .n .u{color:var(--ochre-soft)}
  .stat .l{margin-top:.5rem;font-size:.92rem;color:#AFC2BA}
  .stats-grid .stat:not(:last-child){border-right:1px solid rgba(255,255,255,.12)}

  /* ============ who it's for ============ */
  .who-sec{background:color-mix(in srgb,var(--ground-2) 70%,var(--paper));border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .pro{display:grid;grid-template-columns:1.05fr .95fr;gap:3rem;align-items:center}
  .pro-card{display:flex;flex-direction:column;gap:.85rem}
  .pro-row{display:flex;gap:.9rem;align-items:flex-start;padding:1rem;border-radius:12px;background:var(--paper);border:1px solid var(--line);transition:transform .18s ease,box-shadow .18s ease}
  .pro-row:hover{transform:translateY(-3px);box-shadow:0 16px 30px -24px rgba(30,42,69,.6)}
  .pro-row .ri{width:40px;height:40px;border-radius:10px;flex:none;display:flex;align-items:center;justify-content:center;background:rgba(47,107,255,.12);color:var(--teal)}
  .pro-row strong{display:block;font-size:1.02rem}
  .pro-row span{font-size:.92rem;color:var(--ink-soft)}

  /* ============ testimonials ============ */
  .quotes{display:grid;grid-template-columns:repeat(3,1fr);gap:1.1rem}
  .quote{background:var(--paper);border:1px solid var(--line);border-radius:var(--r);padding:1.6rem}
  .quote .q{font-family:"Fraunces",serif;font-size:1.1rem;line-height:1.42;letter-spacing:-.01em;margin-bottom:1.2rem}
  .quote .who2{display:flex;align-items:center;gap:.7rem}
  .quote .av{width:38px;height:38px;border-radius:50%;flex:none;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;color:#fff}
  .quote .who2 b{font-size:.92rem;display:block}
  .quote .who2 span{font-size:.82rem;color:var(--ink-soft)}

  /* ============ cta ============ */
  .cta-box{background:linear-gradient(135deg,#23489E,#16306B);border-radius:24px;padding:clamp(40px,6vw,72px);text-align:center;position:relative;overflow:hidden}
  .cta-box::before{content:"";position:absolute;left:-10%;top:-40%;width:50%;height:180%;background:radial-gradient(circle,rgba(245,179,18,.22),transparent 60%)}
  .cta-box::after{content:"";position:absolute;right:-10%;bottom:-40%;width:50%;height:180%;background:radial-gradient(circle,rgba(47,107,255,.35),transparent 60%)}
  .cta-box>*{position:relative;z-index:1}
  .cta-box h2{color:#F2F5F1;margin-bottom:1rem}
  .cta-box p{color:#C5D3CC;max-width:540px;margin:0 auto 2rem;font-size:1.08rem}
  .cta-box .btn-primary{background:var(--ochre);color:#1c1206}
  .cta-box .btn-primary:hover{background:var(--ochre-soft)}
  .cta-box .btn-ghost{color:#EAF0EC;border-color:rgba(255,255,255,.3)}
  .cta-box .btn-ghost:hover{border-color:#fff}

  /* sign-up form */
  .signup{display:flex;gap:.6rem;max-width:460px;margin:0 auto;flex-wrap:wrap;justify-content:center}
  .signup .hp{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden}
  .signup input[type=email]{flex:1 1 220px;min-width:0;padding:.9em 1.25em;border-radius:999px;border:1px solid rgba(255,255,255,.28);background:rgba(255,255,255,.08);color:#F2F5F1;font-family:inherit;font-size:1rem;outline:none;transition:border-color .15s ease,background .15s ease}
  .signup input[type=email]::placeholder{color:#9fb3ab}
  .signup input[type=email]:focus{border-color:var(--ochre-soft);background:rgba(255,255,255,.14)}
  .signup .btn{flex:0 0 auto}
  .signup-note{margin-top:1rem;font-size:.85rem;color:#9fb3ab}
  .signup-error{color:#f0bfa6;font-size:.88rem;margin-top:.7rem;min-height:.5em;font-weight:500}
  .signup-success{display:none;flex-direction:column;align-items:center;gap:.55rem;animation:popIn .4s ease}
  .signup-success.show{display:flex}
  .signup-success .tick{width:54px;height:54px;border-radius:50%;background:var(--go);color:#fff;display:flex;align-items:center;justify-content:center;margin-bottom:.2rem}
  .signup-success b{font-family:"Fraunces",serif;font-size:1.5rem;font-weight:500;color:#F2F5F1}
  .signup-success span{color:#C5D3CC;font-size:.96rem}
  @keyframes popIn{from{opacity:0;transform:scale(.94)}to{opacity:1;transform:none}}

  footer{border-top:1px solid var(--line);padding:56px 0 32px}
  .foot-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:2rem}
  .foot-brand .brand{margin-bottom:.9rem}
  .foot-brand p{font-size:.92rem;color:var(--ink-soft);max-width:300px}
  .foot-col h4{font-family:"Spline Sans Mono",monospace;font-size:.72rem;text-transform:uppercase;letter-spacing:.16em;color:var(--ink-soft);margin-bottom:1rem;font-weight:500}
  .foot-col a{display:block;font-size:.95rem;color:var(--ink-soft);margin-bottom:.6rem;transition:color .15s ease}
  .foot-col a:hover{color:var(--ink)}
  .foot-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-top:2.6rem;padding-top:1.6rem;border-top:1px solid var(--line);font-size:.85rem;color:var(--ink-soft)}

  .reveal{opacity:0;transform:translateY(18px);transition:opacity .7s ease,transform .7s ease}
  .reveal.in{opacity:1;transform:none}

  @keyframes seamIn{to{opacity:.9}}
  @keyframes slideIn{to{transform:translateX(0);opacity:1}}
  @keyframes pulse{0%,100%{box-shadow:0 0 0 4px rgba(21,184,119,.16)}50%{box-shadow:0 0 0 9px rgba(21,184,119,.06)}}
  .track.close .zone{animation:pulse 2s ease-in-out infinite}

  @media(max-width:900px){
    .nav-links{display:none}.nav-cta .signin{display:none}.menu-btn{display:flex}
    .feat-grid,.quotes{grid-template-columns:1fr 1fr}
    .roles{grid-template-columns:1fr}
    .steps{grid-template-columns:1fr 1fr;gap:0 1.4rem}.step:not(:last-child){margin-right:0}
    .stats-grid{grid-template-columns:1fr 1fr;gap:1.6rem}.stats-grid .stat:nth-child(2){border-right:none}
    .pro{grid-template-columns:1fr;gap:2rem}
    .foot-grid{grid-template-columns:1fr 1fr}
  }
  @media(max-width:560px){
    body{font-size:16px}
    .feat-grid,.quotes,.stats-grid,.steps{grid-template-columns:1fr}
    .stats-grid .stat{border-right:none!important;border-bottom:1px solid rgba(255,255,255,.12);padding-bottom:1.4rem}
    .stats-grid .stat:last-child{border-bottom:none}
    .hero-actions{flex-direction:column}.hero-actions .btn{justify-content:center}
    .foot-grid{grid-template-columns:1fr}
    .hero h1 .mid{white-space:normal}
  }
  @media(prefers-reduced-motion:reduce){
    *{animation:none!important;transition:none!important}
    .reveal{opacity:1;transform:none}.seam{opacity:.9}.hero-side{opacity:1;transform:none}
  }
  :focus-visible{outline:2px solid var(--teal);outline-offset:3px;border-radius:4px}
</style>
</head>
<body>

<header class="nav" id="nav">
  <div class="wrap nav-inner">
    <a class="brand" href="#top" aria-label="MidBid home">

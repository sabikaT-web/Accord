          <div class="mark claim" id="markClaim"><span class="bubble" id="bubClaim">£58,000</span></div>
        </div>
        <div class="ticks"><span>£0</span><span>£20k</span><span>£40k</span><span>£60k</span><span>£80k</span></div>
      </div>


<%- include('partials/head') %>
<% var joinerOwes = (c.claimant_id != null); var mid = Math.round(c.amount/2); %>
<h1 class="page serif">You're invited to settle — your way</h1>
<p class="sub">No haggling, no lawyers. You choose your own private number to begin.</p>
<div class="card">
  <h2><%= c.title %></h2>
  <p class="muted" style="margin:.3rem 0 1rem">Case MB-<%= c.id %> · £<%= fmt(c.amount) %> in question</p>

  <p style="margin-bottom:.4rem"><strong>You're in control of your number.</strong>
    Slide to <%= joinerOwes ? "the most you'd be willing to pay" : "the least you'd be willing to accept" %>.
    It stays private — the other side never sees it, and you only get a nudge when you're close.</p>

  <form method="POST" action="/join/<%= c.invite_token %>/accept">
    <div style="background:#F6F8FF;border-radius:12px;padding:16px;margin:1rem 0">
      <div style="display:flex;justify-content:space-between;font-size:.85rem;color:#667">
        <span>£0</span><span>It's your call</span><span>£<%= fmt(c.amount) %></span>
      </div>
      <input id="figure" name="value" type="range" min="0" max="<%= c.amount %>" value="<%= mid %>"
             step="1" style="width:100%;margin:.5rem 0;accent-color:#2F6BFF" />
      <div style="text-align:center;font-weight:600;color:#16306B">
        <%= joinerOwes ? "You'd pay up to" : "You'd accept from" %> <span id="figureVal">£<%= fmt(mid) %></span>
      </div>
    </div>
    <div class="btn-block">
      <button class="btn btn-primary" type="submit" id="goBtn">Continue with £<%= fmt(mid) %></button>
    </div>
  </form>
  <p class="muted" style="font-size:.85rem;margin-top:.6rem">Choosing your figure creates your account and joins the case. You can change the number any time afterwards.</p>
</div>
<script>
  (function () {
    var s = document.getElementById('figure'),
        out = document.getElementById('figureVal'),
        btn = document.getElementById('goBtn');
    function money(v) { return '£' + Number(v).toLocaleString('en-GB'); }
    if (s) s.addEventListener('input', function () {
      out.textContent = money(s.value);
      btn.textContent = 'Continue with ' + money(s.value);
    });
  })();
</script>
<%- include('partials/foot') %>

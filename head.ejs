<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MidBid</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
</head>
<body>
<header class="bar">
  <div class="bar-in">
    <a class="brand" href="/">
      <svg viewBox="0 0 32 32" fill="none"><circle cx="11" cy="16" r="8.5" stroke="#2F6BFF" stroke-width="2.4"/><circle cx="21" cy="16" r="8.5" stroke="#F5B312" stroke-width="2.4"/></svg>
      MidBid
    </a>
    <div class="bar-right">
      <% if (me) { %>
        <a href="/dashboard">My cases</a>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %><a href="/admin" class="admin-link">Admin</a><% } %>
        <span class="muted"><%= me.name %></span>
        <form method="POST" action="/logout"><button class="linkbtn" type="submit">Log out</button></form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/signup">Sign up</a>
      <% } %>
    </div>
  </div>
</header>
<main><div class="wrap">

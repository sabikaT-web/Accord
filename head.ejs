<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MidBid</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Hanken+Grotesk:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<style>
/* Portal switch. Scoped here so styles.css needs no changes. */
.portal-seg{display:flex;background:#EAEFF7;border:1px solid #DCE3EF;border-radius:999px;padding:3px;font-size:.84rem;font-weight:600;margin:0 auto}
.portal-seg form{margin:0;display:flex}
.portal-seg button{border:none;background:none;font:inherit;font-weight:600;color:#586079;padding:.4em 1em;border-radius:999px;cursor:pointer;white-space:nowrap}
.portal-seg button.on{background:#fff;color:#16306B;box-shadow:0 1px 3px rgba(22,48,107,.12)}
@media (max-width:760px){.portal-seg{font-size:.78rem;margin:0}.portal-seg button{padding:.35em .7em}}
</style>
</head>
<body>
<div class="seam-top"></div>
<header class="bar">
  <div class="bar-in">
    <a class="brand" href="/">
      <svg style="width:32px;height:32px;flex:none" viewBox="14 14 72 72" xmlns="http://www.w3.org/2000/svg"><defs>
   <filter id="gH" x="-80%" y="-80%" width="260%" height="260%"><feGaussianBlur stdDeviation="2.2"/></filter>
   <clipPath id="mkH"><circle cx="44.0" cy="50" r="18"/></clipPath><circle cx="44.0" cy="50" r="18" fill="#2F6BFF"/><circle cx="56.0" cy="50" r="18" fill="#F5B312"/><g clip-path="url(#mkH)"><circle cx="56.0" cy="50" r="18" fill="#15B877"/></g></defs>
 <circle cx="50" cy="50" r="4" fill="#15B877" filter="url(#gH)" opacity="0">
   <animate attributeName="r" values="2;20;2;20;2" keyTimes="0;0.25;0.5;0.75;1" dur="3.4s" repeatCount="indefinite"/>
   <animate attributeName="opacity" values="0;0.8;0;0.8;0" keyTimes="0;0.25;0.5;0.75;1" dur="3.4s" repeatCount="indefinite"/></circle>
 <g><circle cx="44" cy="50" r="18" fill="#2F6BFF"/><circle cx="56" cy="50" r="18" fill="#F5B312"/>
   <g clip-path="url(#mkH)"><circle cx="56" cy="50" r="18" fill="#15B877"/></g></g>
 <g><animateTransform attributeName="transform" type="rotate" from="0 50 50" to="360 50 50" dur="3.4s" repeatCount="indefinite"/>
   <circle cx="50" cy="24" r="4" fill="#2F6BFF" filter="url(#gH)"/></g>
 <g><animateTransform attributeName="transform" type="rotate" from="180 50 50" to="540 50 50" dur="3.4s" repeatCount="indefinite"/>
   <circle cx="50" cy="24" r="4" fill="#F5B312" filter="url(#gH)"/></g></svg>
      MidBid
    </a>

    <%# Individual / business switch. Only for signed-in users. %>
    <% if (me) { %>
      <div class="portal-seg" role="group" aria-label="Choose portal">
        <form method="POST" action="/business/switch">
          <input type="hidden" name="type" value="individual" />
          <button type="submit" class="<%= me.account_type === 'business' ? '' : 'on' %>">For individuals</button>
        </form>
        <form method="POST" action="/business/switch">
          <input type="hidden" name="type" value="business" />
          <button type="submit" class="<%= me.account_type === 'business' ? 'on' : '' %>">For business</button>
        </form>
      </div>
    <% } %>

    <div class="bar-right">
      <% if (me) { %>
        <% if (me.account_type === 'business') { %>
          <a href="/business">Disputes</a>
        <% } else { %>
          <a href="/dashboard">My cases</a>
        <% } %>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %><a href="/admin" class="admin-link">Admin</a><% } %>
        <span class="muted"><%= me.company_name || me.name %></span>
        <form method="POST" action="/logout"><button class="linkbtn" type="submit">Log out</button></form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/signup">Sign up</a>
      <% } %>
    </div>
  </div>
</header>
<main>
<%# Pages opt in to the navy banner by passing a pageHead object with eyebrow, title, sub. %>
<%# Pages that pass nothing render exactly as they did before. %>
<% if (typeof pageHead !== 'undefined' && pageHead) { %>
  <div class="page-head">
    <div class="wrap">
      <% if (pageHead.eyebrow) { %><div class="eyebrow"><%= pageHead.eyebrow %></div><% } %>
      <h1 class="page"><%= pageHead.title %></h1>
      <% if (pageHead.sub) { %><p class="sub"><%- pageHead.sub %></p><% } %>
    </div>
  </div>
<% } %>
<div class="wrap">
